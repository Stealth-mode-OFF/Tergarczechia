---
type Crumb = { label: string; href: string };

type Props = {
  type?: 'home' | 'article' | 'event' | 'faq' | null;
  title?: string;
  description?: string;
  breadcrumbs?: Crumb[];
};

const { type = 'home', description, breadcrumbs } = Astro.props as Props;

const SITE = 'https://tergarczechia.cz';
const SITE_NAME = 'Tergar Česko';
const LOGO = `${SITE}/og-logo.png`;

const org = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'NGO', 'ReligiousOrganization'],
  '@id': `${SITE}/#organization`,
  name: SITE_NAME,
  alternateName: ['Tergar Czechia', 'Tergar ČR'],
  url: SITE,
  logo: {
    '@type': 'ImageObject',
    url: LOGO,
    width: 1500,
    height: 494,
  },
  image: `${SITE}/og-default.png`,
  description: 'Česká pobočka mezinárodní meditační komunity Tergar pod vedením Yongey Mingyur Rinpočheho. Učení tradice Karma Kagjü, Joy of Living a Path of Liberation.',
  email: 'czech@tergar.org',
  foundingDate: '2015',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Školská 28',
    addressLocality: 'Praha',
    postalCode: '110 00',
    addressCountry: 'CZ',
    addressRegion: 'Praha 1',
  },
  areaServed: [
    { '@type': 'Country', name: 'Česká republika' },
    { '@type': 'City', name: 'Praha' },
    { '@type': 'City', name: 'České Budějovice' },
    { '@type': 'City', name: 'Česká Lípa' },
  ],
  knowsLanguage: ['cs', 'en'],
  sameAs: [
    'https://www.facebook.com/tergarcz/',
    'https://www.instagram.com/tergar_cz',
    'https://www.youtube.com/@tergarczechia1847',
    'https://tergar.org',
  ],
  parentOrganization: {
    '@type': 'Organization',
    '@id': 'https://tergar.org/#organization',
    name: 'Tergar International',
    url: 'https://tergar.org',
  },
  founder: {
    '@type': 'Person',
    name: 'Yongey Mingyur Rinpočhe',
    url: 'https://tergar.org/yongey-mingyur-rinpoche',
    sameAs: [
      'https://en.wikipedia.org/wiki/Yongey_Mingyur_Rinpoche',
      'https://www.wikidata.org/wiki/Q1780225',
    ],
  },
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  name: SITE_NAME,
  url: SITE,
  inLanguage: 'cs-CZ',
  description: description,
  publisher: { '@id': `${SITE}/#organization` },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE}/hledat?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

const crumb = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.label,
        item: new URL(c.href, SITE).toString(),
      })),
    }
  : null;
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(org)} />
{type === 'home' && <script is:inline type="application/ld+json" set:html={JSON.stringify(website)} />}
{crumb && <script is:inline type="application/ld+json" set:html={JSON.stringify(crumb)} />}
