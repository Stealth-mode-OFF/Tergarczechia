---
type Props = { variant?: 'line' | 'wave' | 'dot'; class?: string };
const { variant = 'line', class: className = '' } = Astro.props;
---

{variant === 'line' && <hr class={`div-line ${className}`} />}
{variant === 'dot' && (
  <div class={`div-dot ${className}`} aria-hidden="true">
    <span />·<span />
  </div>
)}
{variant === 'wave' && (
  <svg class={`div-wave ${className}`} viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M0,30 C240,50 480,10 720,20 C960,30 1200,50 1440,30"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      opacity=".35"
    />
  </svg>
)}

<style>
  .div-line {
    border: 0;
    height: 1px;
    background: var(--line);
    margin-block: 2.5rem;
  }
  .div-dot {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink-soft);
    font-size: 1.25rem;
    margin-block: 2.5rem;
    letter-spacing: 0.5em;
  }
  .div-dot span {
    display: inline-block;
    width: 64px;
    height: 1px;
    background: var(--line);
  }
  .div-wave {
    display: block;
    width: 100%;
    height: 40px;
    color: var(--accent-soft);
  }
</style>
