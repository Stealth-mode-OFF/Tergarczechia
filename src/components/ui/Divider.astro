---
type Props = { variant?: 'line' | 'wave' | 'dot' | 'wheel'; class?: string };
const { variant = 'line', class: className = '' } = Astro.props;
---

{variant === 'line' && <hr class={`div-line ${className}`} />}

{variant === 'dot' && (
  <div class={`div-dot ${className}`} aria-hidden="true">
    <span />·<span />
  </div>
)}

{variant === 'wave' && (
  <svg class={`div-wave ${className}`} viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M0,30 C240,50 480,10 720,20 C960,30 1200,50 1440,30"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      opacity=".35"
    />
  </svg>
)}

{variant === 'wheel' && (
  <div class={`div-wheel ${className}`} aria-hidden="true">
    <span class="div-wheel-line"></span>
    <svg viewBox="0 0 40 40" width="28" height="28" class="div-wheel-mark">
      {/* Hand-drawn dharma wheel — slightly wobbly, 8 spokes for Noble Eightfold Path */}
      <circle cx="20" cy="20" r="15.2" fill="none" stroke="currentColor" stroke-width="1.1" opacity="0.9"/>
      <circle cx="20" cy="20" r="4.8" fill="none" stroke="currentColor" stroke-width="1" opacity="0.8"/>
      {/* 8 spokes with 0.35deg wobble each for handdrawn feel */}
      <g stroke="currentColor" stroke-width="0.9" opacity="0.75" stroke-linecap="round">
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(0.3 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(45.4 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(90.2 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(134.8 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(180 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(225.3 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(269.7 20 20)"/>
        <line x1="20" y1="5.2" x2="20" y2="15.1" transform="rotate(314.6 20 20)"/>
      </g>
      <circle cx="20" cy="20" r="1.4" fill="currentColor" opacity="0.85"/>
    </svg>
    <span class="div-wheel-line"></span>
  </div>
)}

<style>
  .div-line {
    border: 0;
    height: 1px;
    background: var(--line);
    margin-block: 2.5rem;
  }
  .div-dot {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink-soft);
    font-size: 1.25rem;
    margin-block: 2.5rem;
    letter-spacing: 0.5em;
  }
  .div-dot span {
    display: inline-block;
    width: 64px;
    height: 1px;
    background: var(--line);
  }
  .div-wave {
    display: block;
    width: 100%;
    height: 40px;
    color: var(--accent-soft);
  }
  .div-wheel {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-block: clamp(3rem, 6vw, 5rem);
    color: var(--accent);
  }
  .div-wheel-line {
    flex: 1;
    max-width: 240px;
    height: 1px;
    background: linear-gradient(90deg, transparent, currentColor, transparent);
    opacity: 0.45;
  }
  .div-wheel-mark {
    color: var(--accent);
    opacity: 0.85;
    flex-shrink: 0;
  }
</style>
