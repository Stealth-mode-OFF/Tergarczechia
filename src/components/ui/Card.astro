---
type Props = {
  href?: string;
  elevated?: boolean;
  accent?: boolean;
  class?: string;
};
const { href, elevated = false, accent = false, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'article';
const classes = [
  'card',
  elevated ? 'card-elevated' : '',
  accent ? 'card-accent' : '',
  className,
].filter(Boolean).join(' ');
---

<Tag href={href} class={classes}><slot /></Tag>

<style>
  .card {
    position: relative;
    display: block;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.75rem;
    color: inherit;
    text-decoration: none;
    transition:
      border-color 280ms var(--ease-out),
      transform 360ms var(--ease-out),
      box-shadow 360ms var(--ease-out),
      background 280ms var(--ease-out);
  }
  @media (min-width: 768px) {
    .card { padding: 2rem; }
  }

  a.card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow:
      0 1px 2px rgba(32, 48, 112, 0.04),
      0 14px 32px -18px rgba(32, 48, 112, 0.22);
  }

  .card-elevated {
    box-shadow:
      0 1px 2px rgba(32, 48, 112, 0.03),
      0 8px 24px -12px rgba(32, 48, 112, 0.12);
  }
  a.card-elevated:hover {
    box-shadow:
      0 2px 4px rgba(32, 48, 112, 0.04),
      0 20px 40px -18px rgba(32, 48, 112, 0.28);
  }

  /* Accent cards — subtle gold top strip revealing on hover */
  .card-accent { padding-top: 1.875rem; }
  .card-accent::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.75rem;
    right: 1.75rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.55;
    transition: opacity 280ms var(--ease-out);
  }
  a.card-accent:hover::before { opacity: 1; }
  @media (min-width: 768px) {
    .card-accent { padding-top: 2.125rem; }
    .card-accent::before { left: 2rem; right: 2rem; }
  }
</style>
