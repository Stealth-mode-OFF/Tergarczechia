---
type Platform = 'instagram' | 'facebook' | 'youtube';
type Variant = 'mono' | 'brand';

interface Props {
  platform: Platform;
  variant?: Variant;
  size?: number;
  title?: string;
}

const { platform, variant = 'mono', size = 20, title } = Astro.props;
const label = title ?? (platform === 'instagram' ? 'Instagram' : platform === 'facebook' ? 'Facebook' : 'YouTube');
---

{platform === 'instagram' && variant === 'mono' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" role="img" aria-label={label}>
    <rect x="3" y="3" width="18" height="18" rx="5.5"/>
    <circle cx="12" cy="12" r="4"/>
    <circle cx="17.25" cy="6.75" r="1" fill="currentColor" stroke="none"/>
  </svg>
)}
{platform === 'instagram' && variant === 'brand' && (
  <svg width={size} height={size} viewBox="0 0 24 24" role="img" aria-label={label}>
    <defs>
      <radialGradient id="ig-grad" cx="30%" cy="105%" r="130%">
        <stop offset="0%" stop-color="#FDCE4E"/>
        <stop offset="25%" stop-color="#FFA024"/>
        <stop offset="50%" stop-color="#F23A44"/>
        <stop offset="75%" stop-color="#C23B90"/>
        <stop offset="100%" stop-color="#6A3BC0"/>
      </radialGradient>
    </defs>
    <rect x="2.5" y="2.5" width="19" height="19" rx="5.25" fill="url(#ig-grad)"/>
    <rect x="2.5" y="2.5" width="19" height="19" rx="5.25" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="0.5"/>
    <circle cx="12" cy="12" r="4" fill="none" stroke="#fff" stroke-width="1.8"/>
    <circle cx="17.3" cy="6.7" r="1.1" fill="#fff"/>
  </svg>
)}

{platform === 'facebook' && variant === 'mono' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" role="img" aria-label={label}>
    <path d="M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.25-1.5 1.55-1.5h1.65V4.65A22 22 0 0 0 14.3 4.5c-2.4 0-4 1.45-4 4.1v2.3H7.6V14h2.7v8h3.2Z"/>
  </svg>
)}
{platform === 'facebook' && variant === 'brand' && (
  <svg width={size} height={size} viewBox="0 0 24 24" role="img" aria-label={label}>
    <circle cx="12" cy="12" r="10" fill="#0866FF"/>
    <path d="M13.2 21.9v-8.35h2.55l.45-3.15h-3V8.55c0-.9.4-1.55 1.75-1.55h1.4V4.2a24 24 0 0 0-2.3-.1c-2.4 0-3.95 1.45-3.95 4.1v2.15H7.5v3.15h2.6V21.9a10 10 0 0 0 3.1 0Z" fill="#fff"/>
  </svg>
)}

{platform === 'youtube' && variant === 'mono' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" role="img" aria-label={label}>
    <path d="M21.6 7.3a2.5 2.5 0 0 0-1.75-1.75C18.3 5.1 12 5.1 12 5.1s-6.3 0-7.85.45A2.5 2.5 0 0 0 2.4 7.3 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.7 2.5 2.5 0 0 0 1.75 1.75C5.7 18.9 12 18.9 12 18.9s6.3 0 7.85-.45A2.5 2.5 0 0 0 21.6 16.7 26 26 0 0 0 22 12a26 26 0 0 0-.4-4.7ZM10 15V9l5.2 3-5.2 3Z"/>
  </svg>
)}
{platform === 'youtube' && variant === 'brand' && (
  <svg width={size} height={size} viewBox="0 0 24 24" role="img" aria-label={label}>
    <path d="M21.6 7.3a2.5 2.5 0 0 0-1.75-1.75C18.3 5.1 12 5.1 12 5.1s-6.3 0-7.85.45A2.5 2.5 0 0 0 2.4 7.3 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.7 2.5 2.5 0 0 0 1.75 1.75C5.7 18.9 12 18.9 12 18.9s6.3 0 7.85-.45A2.5 2.5 0 0 0 21.6 16.7 26 26 0 0 0 22 12a26 26 0 0 0-.4-4.7Z" fill="#FF0033"/>
    <path d="M10 15V9l5.2 3-5.2 3Z" fill="#fff"/>
  </svg>
)}
