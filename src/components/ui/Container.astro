---
type Props = {
  size?: 'prose' | 'default' | 'wide';
  as?: string;
  class?: string;
};
const { size = 'default', as = 'div', class: className = '' } = Astro.props;
const Tag = as as any;
const cls = `container-${size} ${className}`.trim();
---

<Tag class={cls}><slot /></Tag>

<style>
  /* Unified horizontal padding — same inset on every page, every breakpoint.
     Uses clamp so spacing scales fluidly without media-query jumps. */
  .container-prose,
  .container-default,
  .container-wide {
    width: 100%;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
  }
  .container-prose { max-width: var(--w-prose); }
  .container-default { max-width: var(--w-content); }
  .container-wide { max-width: var(--w-wide); }
</style>
