---
type Props = {
  size?: 'prose' | 'default' | 'wide';
  as?: string;
  class?: string;
};
const { size = 'default', as = 'div', class: className = '' } = Astro.props;
const Tag = as as any;
const cls = `container-${size} ${className}`.trim();
---

<Tag class={cls}><slot /></Tag>

<style>
  .container-prose {
    width: 100%;
    max-width: var(--w-prose);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  .container-default {
    width: 100%;
    max-width: var(--w-content);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  .container-wide {
    width: 100%;
    max-width: var(--w-wide);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  @media (min-width: 768px) {
    .container-prose, .container-default, .container-wide { padding-inline: 2rem; }
  }
  @media (min-width: 1024px) {
    .container-default, .container-wide { padding-inline: 2.5rem; }
  }
</style>
