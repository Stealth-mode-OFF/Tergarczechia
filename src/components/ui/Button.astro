---
type Props = {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'link';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  type?: 'button' | 'submit';
  class?: string;
};

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  type = 'button',
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
const classes = ['btn', `btn-${variant}`, `btn-${size}`, className].filter(Boolean).join(' ');
---

<Tag href={href} type={!href ? type : undefined} target={target} rel={rel} class={classes}>
  <slot />
  {external && (
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M3 9 L9 3 M4.5 3 L9 3 L9 7.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    white-space: nowrap;
    border-radius: var(--radius-md);
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
    cursor: pointer;
    text-decoration: none;
    line-height: 1;
  }
  .btn-sm { padding: 0.5rem 0.875rem; font-size: 0.8125rem; }
  .btn-md { padding: 0.75rem 1.25rem; font-size: 0.9375rem; }
  .btn-lg { padding: 0.9375rem 1.75rem; font-size: 1rem; }

  .btn-primary {
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
  }
  .btn-primary:hover { background: var(--accent); border-color: var(--accent); }

  .btn-secondary {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--line-strong);
  }
  .btn-secondary:hover { border-color: var(--ink); background: var(--surface); }

  .btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid transparent;
  }
  .btn-ghost:hover { background: var(--surface); }

  .btn-link {
    background: transparent;
    color: var(--ink);
    padding: 0;
    border: 0;
    border-radius: 0;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }
  .btn-link:hover { color: var(--accent); }
</style>
