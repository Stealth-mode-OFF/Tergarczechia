---
type Props = { author?: string; class?: string };
const { author, class: className = '' } = Astro.props;
---

<figure class={`quote ${className}`.trim()}>
  <blockquote>
    <slot />
  </blockquote>
  {author && <figcaption>— {author}</figcaption>}
</figure>

<style>
  .quote {
    margin: 2.5rem auto;
    max-width: 56ch;
    text-align: center;
  }
  .quote blockquote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.375rem, 2.4vw, 1.875rem);
    line-height: 1.4;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }
  .quote figcaption {
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
</style>
