---
import MobileMenu from './MobileMenu.tsx';

const nav = [
  { label: 'Meditace', href: '/meditace' },
  { label: 'Časovač', href: '/casovac' },
  { label: 'Cesta', href: '/cesta' },
  { label: 'Skupiny', href: '/skupiny' },
  { label: 'Akce', href: '/akce' },
  { label: 'Zdroje', href: '/zdroje' },
  { label: 'O nás', href: '/o-nas' },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<div class="dharma-ribbon" transition:persist aria-hidden="false">
  <div class="container-wide ribbon-inner">
    <span class="ribbon-dot" aria-hidden="true"></span>
    <span class="ribbon-text">Tergar Czechia&nbsp;·&nbsp;Cesta probuzené mysli</span>
    <span class="ribbon-dot" aria-hidden="true"></span>
  </div>
</div>

<header class="site-header" transition:persist>
  <div class="header-cap">
    <div class="header-inner">
      <a href="/" class="brand" aria-label="Tergar Česko — domů">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="16" cy="16" r="13" />
            <path d="M16 3 v26 M3 16 h26" opacity=".3" />
            <path d="M6 16 Q16 5 26 16 Q16 27 6 16 Z" opacity=".55" />
          </svg>
        </span>
        <span class="brand-text">
          <span class="brand-name">Tergar</span>
          <span class="brand-sub">Česko</span>
        </span>
      </a>

      <nav class="primary-nav" aria-label="Hlavní">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="header-cta">
        <a href="/daru" class="cta-donate">Podpořte</a>
        <MobileMenu nav={nav} activePath={pathname} client:media="(max-width: 960px)" />
      </div>
    </div>
  </div>
</header>

<style>
  .dharma-ribbon {
    background: var(--tergar-maroon);
    color: var(--tergar-lotus);
    position: sticky;
    top: 0;
    z-index: 41;
    border-bottom: 1px solid rgba(246, 231, 200, 0.08);
  }
  .ribbon-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    height: 34px;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
  }
  .ribbon-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--tergar-saffron-pale);
    opacity: 0.8;
  }
  .ribbon-text {
    text-align: center;
  }
  @media (max-width: 540px) {
    .ribbon-inner { height: 30px; font-size: 0.625rem; letter-spacing: 0.18em; gap: 0.5rem; }
    .ribbon-text { font-size: 0.625rem; }
  }

  .site-header {
    position: sticky;
    top: 34px;
    z-index: 40;
    padding: 0.875rem 1rem 0;
    pointer-events: none;
  }
  @media (max-width: 540px) {
    .site-header { top: 30px; padding: 0.625rem 0.75rem 0; }
  }
  .header-cap {
    pointer-events: auto;
    max-width: 1120px;
    margin-inline: auto;
    background: color-mix(in oklab, #FFFCF5 92%, transparent);
    border: 1px solid rgba(233, 221, 200, 0.7);
    border-radius: 2rem;
    box-shadow: 0 18px 65px -35px rgba(28, 43, 58, 0.45);
    backdrop-filter: saturate(1.2) blur(14px);
    -webkit-backdrop-filter: saturate(1.2) blur(14px);
    transition: box-shadow var(--dur-med) var(--ease-out), border-color var(--dur-med) var(--ease-out);
  }
  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    height: 68px;
    padding-inline: 1.25rem;
  }
  @media (min-width: 768px) {
    .header-inner { padding-inline: 1.75rem; }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--ink);
    text-decoration: none;
  }
  .brand-mark {
    color: var(--tergar-maroon);
    display: inline-flex;
    transition: color var(--dur-med) var(--ease-out);
  }
  .brand:hover .brand-mark { color: var(--accent); }
  .brand-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.375rem;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-size: 0.8125rem;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  .primary-nav {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
  }
  @media (min-width: 960px) {
    .primary-nav { display: flex; }
  }
  .nav-link {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--ink) 65%, transparent);
    text-decoration: none;
    padding: 0.5rem 0.25rem;
    position: relative;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.25rem;
    right: 0.25rem;
    bottom: 0.125rem;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-med) var(--ease-out);
  }
  .nav-link:hover, .nav-link:focus-visible { color: var(--accent); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.active { color: var(--accent); }
  .nav-link.active::after { transform: scaleX(1); }

  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cta-donate {
    display: none;
    padding: 0.5rem 1.125rem;
    background: var(--tergar-maroon);
    color: var(--tergar-lotus);
    border: 1px solid var(--tergar-maroon);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  @media (min-width: 640px) {
    .cta-donate { display: inline-flex; }
  }
  .cta-donate:hover {
    background: var(--accent-deep, var(--tergar-maroon));
    box-shadow: 0 8px 24px -10px rgba(122, 38, 53, 0.5);
  }
</style>
