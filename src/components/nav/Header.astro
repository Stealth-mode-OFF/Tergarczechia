---
import { Image } from 'astro:assets';
import logoImage from '@/assets/logo.png';
import MobileMenu from './MobileMenu.tsx';

const nav = [
  { label: 'Začít', href: '/meditace' },
  { label: 'Skupiny', href: '/skupiny' },
  { label: 'Akce', href: '/akce' },
  { label: 'Cesta', href: '/cesta' },
  { label: 'Zdroje', href: '/zdroje' },
  { label: 'O nás', href: '/o-nas' },
];
const quickLinks = [
  { label: 'Časovač', href: '/casovac' },
  { label: 'Podpořte nás', href: '/daru' },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<header class="site-header" transition:persist>
  <div class="header-cap">
    <div class="header-inner">
      <a href="/" class="brand" aria-label="Tergar Česko — domů">
        <Image src={logoImage} alt="Tergar" class="brand-logo" widths={[200, 300, 400]} sizes="200px" loading="eager" />
        <span class="brand-tag">Česko</span>
      </a>

      <nav class="primary-nav" aria-label="Hlavní">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="header-cta">
        <a href="/daru" class="cta-support">Podpořte</a>
        <a href="/meditace" class:list={['cta-start', { active: isActive('/meditace') }]}>Začít zdarma</a>
        <MobileMenu nav={nav} quickLinks={quickLinks} activePath={pathname} client:media="(max-width: 959px)" />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: saturate(1.2) blur(12px);
    -webkit-backdrop-filter: saturate(1.2) blur(12px);
    border-bottom: 1px solid rgba(232, 228, 221, 0.8);
  }
  .header-cap {
    max-width: 1280px;
    margin-inline: auto;
  }
  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    height: 72px;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
  }
  @media (min-width: 768px) {
    .header-inner { height: 78px; }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
    text-decoration: none;
  }
  .brand-logo {
    height: 34px;
    width: auto;
    display: block;
  }
  @media (min-width: 768px) {
    .brand-logo { height: 40px; }
  }
  .brand-tag {
    display: none;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--tergar-navy);
    letter-spacing: 0.01em;
    padding-left: 0.75rem;
    border-left: 1px solid var(--line);
    line-height: 1;
  }
  @media (min-width: 640px) {
    .brand-tag { display: inline; }
  }

  .primary-nav {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 1.75rem;
  }
  @media (min-width: 960px) {
    .primary-nav { display: flex; }
  }
  .nav-link {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--tergar-navy) 70%, transparent);
    text-decoration: none;
    padding: 0.5rem 0.125rem;
    position: relative;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.125rem;
    right: 0.125rem;
    bottom: 0.125rem;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-med) var(--ease-out);
  }
  .nav-link:hover, .nav-link:focus-visible { color: var(--tergar-navy); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.active { color: var(--tergar-navy); }
  .nav-link.active::after { transform: scaleX(1); }

  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cta-support {
    display: none;
    color: var(--ink-muted);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 0.25rem;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .cta-support:hover {
    color: var(--tergar-navy);
  }
  .cta-start {
    display: none;
    padding: 0.5rem 1.125rem;
    background: linear-gradient(135deg, var(--accent) 0%, #E7B14B 100%);
    color: var(--tergar-navy);
    border: 1px solid color-mix(in oklab, var(--accent) 82%, white 18%);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
    box-shadow: 0 4px 14px -4px rgba(224, 160, 32, 0.35);
  }
  .cta-start:hover {
    background: linear-gradient(135deg, var(--accent-hover) 0%, #C98C17 100%);
    color: #FFFFFF;
    box-shadow: 0 8px 22px -8px rgba(224, 160, 32, 0.58);
    transform: translateY(-1px);
  }
  .cta-start.active {
    box-shadow:
      0 0 0 1px color-mix(in oklab, var(--accent-hover) 72%, white 28%),
      0 8px 22px -8px rgba(224, 160, 32, 0.48);
  }
  @media (min-width: 520px) {
    .cta-start { display: inline-flex; }
  }
  @media (min-width: 960px) {
    .cta-support { display: inline-flex; }
  }
</style>
