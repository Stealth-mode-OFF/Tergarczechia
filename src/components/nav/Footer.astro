---
import { Image } from 'astro:assets';
import logoImage from '@/assets/logo.png';

const year = new Date().getFullYear();

const nav = [
  { heading: 'Meditace', links: [
    { label: 'Co je meditace', href: '/meditace' },
    { label: 'Cesta Tergar', href: '/cesta' },
    { label: 'Slovník pojmů', href: '/slovnik' },
    { label: 'Zdroje', href: '/zdroje' },
  ]},
  { heading: 'Komunita', links: [
    { label: 'Skupiny', href: '/skupiny' },
    { label: 'Akce', href: '/akce' },
    { label: 'Rozvrh', href: '/rozvrh' },
    { label: 'Zapojte se', href: '/zapojte-se' },
  ]},
  { heading: 'O nás', links: [
    { label: 'Tergar Česko', href: '/o-nas' },
    { label: 'Kontakt', href: '/kontakt' },
    { label: 'Podpořte nás', href: '/daru' },
    { label: 'Tergar International ↗', href: 'https://tergar.org' },
  ]},
];

const social = [
  { label: 'Facebook', href: 'https://www.facebook.com/tergarcz/' },
  { label: 'Instagram', href: 'https://instagram.com/tergar_cz' },
  { label: 'YouTube', href: 'https://www.youtube.com/@tergarczechia1847' },
];
---

<footer class="site-footer">
  <div class="dharma-line" aria-hidden="true"></div>
  <svg class="wave-divider" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,30 C240,50 480,10 720,20 C960,30 1200,50 1440,30 L1440,60 L0,60 Z"
          fill="currentColor" opacity=".12" />
  </svg>

  <div class="container-wide footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand-row" aria-label="Tergar Česko — domů">
        <Image src={logoImage} alt="Tergar" class="brand-logo" widths={[160, 240, 320]} sizes="160px" densities={[1, 2]} loading="lazy" />
        <span class="brand-tag">Česko</span>
      </a>
      <p class="brand-lead">
        Meditační komunita Yongey Mingyur Rinpočheho v&nbsp;České republice.
        Učení tradice Karma Kagjü — od&nbsp;prvních kroků až&nbsp;po&nbsp;pokročilou praxi.
      </p>
      <div class="social">
        {social.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="social-link">{s.label}</a>
        ))}
      </div>
    </div>

    {nav.map((col) => (
      <div class="footer-col">
        <h5>{col.heading}</h5>
        <ul>
          {col.links.map((l) => {
            const isExternal = /^https?:\/\//.test(l.href);
            return (
              <li>
                <a
                  href={l.href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                >
                  {l.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>

  <div class="container-wide footer-bottom">
    <p>© {year} Tergar Česko · součást Tergar International</p>
    <p class="addr">
      Tibet Open House, Školská 28, 110 00 Praha 1 ·
      <a href="mailto:czech@tergar.org">czech@tergar.org</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--section-md);
    padding-bottom: 2.5rem;
    background: var(--surface);
    color: var(--ink);
    position: relative;
  }
  .dharma-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(224, 160, 32, 0.5), rgba(32, 48, 112, 0.35), rgba(224, 160, 32, 0.5), transparent);
  }
  .wave-divider { color: var(--surface-strong); }
  .footer-grid {
    display: grid;
    gap: var(--gap-md);
    padding-block: clamp(3rem, 6vw, 4.5rem) clamp(2rem, 4vw, 3rem);
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .footer-grid { grid-template-columns: 1.5fr 1fr 1fr 1fr; } }
  .footer-brand { display: flex; flex-direction: column; gap: 1.25rem; }
  .brand-row {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    width: fit-content;
  }
  .brand-logo { height: 30px; width: auto; display: block; }
  .brand-tag {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--tergar-navy);
    padding-left: 0.75rem;
    border-left: 1px solid var(--line);
    line-height: 1;
  }
  .brand-lead { color: var(--ink-muted); max-width: 34ch; font-size: 0.9375rem; line-height: 1.6; }
  .social { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.25rem; }
  .social-link {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color .15s, border-color .15s;
  }
  .social-link:hover { color: var(--ink); border-color: var(--accent); }
  .footer-col h5 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }
  .footer-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-col a {
    color: var(--ink);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color .15s;
  }
  .footer-col a:hover { color: var(--accent); }
  .footer-bottom {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--ink-muted);
    font-size: 0.8125rem;
  }
  .footer-bottom a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
  .footer-bottom a:hover { color: var(--ink); }
</style>
