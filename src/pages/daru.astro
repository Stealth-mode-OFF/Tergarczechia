---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import Quote from '@/components/ui/Quote.astro';
import Card from '@/components/ui/Card.astro';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Podpořte nás', href: '/daru' },
];

const darujmeUrl = 'https://darujme.cz/projekt/1202868';
const bankAccount = '2001592859/2010';
---

<BaseLayout
  title="Podpořte nás — Tergar Česko"
  description="Tergar Česko je nezisková meditační komunita. Každý dar — jednorázový i pravidelný — udržuje skupiny, překlady, retreaty a setkání v ČR."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Podpořte"
        title="Česká sangha žije z vašich darů."
        lede="Tergar Česko není firma. Nikdo tu nemá plat, žádný dar neznačí profitu. Peníze jdou přímo na pronájmy prostor, překlady knih a materiálů, cestovné lektorů, technické vybavení a podporu mezinárodního Tergar."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Darujte online"
        title="Tři cesty, jedna sangha."
        lede="Vyberte si, co vám sedí — rychlé online darování, převodem z účtu, nebo věnujte čas místo peněz."
      />
      <div class="give-grid">
        <Card elevated class="give-card primary">
          <div>
            <h3>Přes darujme.cz</h3>
            <p>
              Nejrychlejší způsob — platební kartou, bankovním převodem nebo Applem/Googlem.
              Můžete nastavit pravidelný měsíční dar i jednorázovou podporu. Potvrzení pro daňové účely obdržíte automaticky.
            </p>
          </div>
          <Button href={darujmeUrl} variant="primary" size="lg" external>Chci podpořit</Button>
        </Card>

        <Card class="give-card">
          <h3>Bankovním převodem</h3>
          <p>
            <strong>{bankAccount}</strong> (Fio banka)<br />
            <span class="muted">Tergar Czech z.s.</span>
          </p>
          <p class="help">
            Jako variabilní symbol uveďte rok + měsíc (např. 202604).
            Pro daňové potvrzení nám napište na <a href="mailto:czech@tergar.org">czech@tergar.org</a>.
          </p>
        </Card>

        <Card class="give-card">
          <h3>Čas místo peněz</h3>
          <p>
            Nemůžete darovat finančně? Pomoc s překlady, organizací akcí, fotografováním nebo
            správou webu je pro nás stejně cenná.
          </p>
          <a href="/zapojte-se" class="link-out">Dobrovolnictví →</a>
        </Card>
      </div>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Kam peníze jdou"
        title="Transparentně, bez marketingových mezitahů."
      />
      <Quote author="Mingyur Rinpočhe">
        „Štědrost není v tom, kolik dáváte. Je v tom, s jakou myslí to děláte."
      </Quote>
      <div class="where-to">
        <ul>
          <li><strong>Pronájmy a provoz</strong> — Tibet Open House, regionální prostory, online licence</li>
          <li><strong>Překlady</strong> — česká verze Joy of Living, knihy, audio meditace</li>
          <li><strong>Podpora lektorů</strong> — cestovné, ubytování českých i zahraničních učitelů</li>
          <li><strong>Technika</strong> — streamování retreatů, audio nahrávky, web</li>
          <li><strong>Podpora Tergar International</strong> — 10 % z darů jde globální sanghe</li>
        </ul>
        <p class="transparent">
          Účetní závěrka je veřejná — najdete ji v obchodním rejstříku pod názvem <em>Tergar Czech z.s.</em>
        </p>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .give-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-default);
  }
  @media (min-width: 900px) { .give-grid { grid-template-columns: 2fr 1fr 1fr; } }
  .give-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .give-card.primary {
    background: var(--ink);
    color: var(--bg);
    border: 0;
  }
  .give-card.primary h3 { color: var(--bg); font-size: 1.5rem; margin: 0 0 0.75rem; }
  .give-card.primary p { color: rgba(255,255,255,.75); margin: 0; }
  .give-card h3 { font-size: 1.375rem; margin: 0 0 0.5rem; letter-spacing: -0.005em; line-height: 1.25; text-wrap: balance; }
  .give-card p { color: var(--ink-muted); margin: 0 0 0.5rem; }
  .give-card .muted { color: var(--ink-soft); }
  .give-card .help { font-size: 0.8125rem; }
  .give-card a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); padding-bottom: 1px; }
  .give-card .link-out {
    display: inline-block;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
  }

  /* "Where to" list — left-aligned on the same rail, no centered island */
  .where-to { max-width: 60rem; margin-top: 2rem; }
  .where-to ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
  }
  .where-to li {
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }
  .where-to li:first-child { border-top: 1px solid var(--line); }
  .where-to li strong { color: var(--ink); font-weight: 600; margin-right: 0.5rem; }
  .transparent { font-size: 0.875rem; color: var(--ink-muted); }
  .transparent em { font-style: italic; }
</style>
