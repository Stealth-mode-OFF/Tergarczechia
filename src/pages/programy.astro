---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import MobileActionBar from '@/components/ui/MobileActionBar.astro';
import { formatDateRange, eventTypeLabel, isFutureOrOngoing } from '@/lib/format';

const events = (await getCollection('events'))
  .filter((e) => isFutureOrOngoing(e.data) || e.data.featured)
  .sort((a, b) => a.data.dateStart.getTime() - b.data.dateStart.getTime())
  .slice(0, 6);

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Programy', href: '/programy' },
];
---

<BaseLayout
  title="Programy a kurzy — Tergar Česko"
  description="Strukturované meditační kurzy Tergar: Anytime Anywhere Meditation, Joy of Living 1–3, Path of Liberation, retreaty a přenosy s Mingyurem Rinpočhem."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Programy"
        title="Kurzy a retreaty."
        lede="Navazující programy od Anytime Anywhere Meditation po Mahámudru. Absolvujete online, s českou skupinou nebo na retreatu."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Programy"
        title="Tři způsoby, jak projít Tergar."
        lede="Stejný cíl, jiný tempo a jiná míra buddhistické tradice. Vyberte si podle zázemí a ambice."
      />
      <div class="tracks cards-3">
        <Card class="track">
          <h3>Joy of Living 1–3</h3>
          <p>Sekulární devítidílný program. Pracujete s dechem, emocemi a soucitem. Otevřený pro začátečníky, bez buddhistických předpokladů.</p>
          <a href="/cesta/02-jol1" class="track-link link-inline">Vstoupit do programu →</a>
        </Card>
        <Card class="track">
          <h3>Path of Liberation 1–5</h3>
          <p>Tradiční buddhistická cesta Mahámudry. Přípravné praxe (ngöndro) + pokročilé meditace.</p>
          <a href="/cesta/05-pol1" class="track-link link-inline">Vstoupit do programu →</a>
        </Card>
        <Card class="track">
          <h3>Vajrayana Online</h3>
          <p>Pokročilé vajrayánové praxe pro absolventy Path of Liberation. Vedeno přímo Mingyurem Rinpočhem.</p>
          <a href="/cesta/10-vajrayana" class="track-link link-inline">Více o programu →</a>
        </Card>
      </div>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Nadcházející akce"
        title="Co se brzy děje."
        lede="Otevřené retreaty, workshopy a přenosy. Celý kalendář níže."
      />
      <div class="upcoming cards-3">
        {events.map((e) => (
          <Card href={`/akce/${e.id}`} class="ev">
            <p class="date">{formatDateRange(e.data.dateStart, e.data.dateEnd)}</p>
            <h3>{e.data.title}</h3>
            <p class="desc">{e.data.description}</p>
            <div class="ev-meta">
              <Badge variant="outline">{eventTypeLabel(e.data.type)}</Badge>
              {e.data.free && <Badge variant="accent">Zdarma</Badge>}
            </div>
          </Card>
        ))}
      </div>
      <div class="upcoming-cta">
        <Button href="/akce" variant="secondary">Všechny akce</Button>
      </div>
    </Container>
  </Section>

  <MobileActionBar
    label="Rychlé akce na stránce programů"
    actions={[
      { label: 'Cesta Tergar', href: '/cesta' },
      { label: 'Kalendář akcí', href: '/akce', variant: 'secondary' },
    ]}
  />
</BaseLayout>

<style>
  .track h3 { font-size: 1.375rem; margin: 0 0 0.75rem; }
  .track p { color: var(--ink-muted); margin: 0 0 1rem; }

  .ev h3 { font-size: 1.125rem; margin: 0.375rem 0 0.5rem; line-height: 1.3; }
  .ev .date { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--accent); margin: 0; }
  .ev .desc { color: var(--ink-muted); font-size: 0.9375rem; margin: 0 0 0.75rem; }
  .ev-meta { display: flex; gap: 0.375rem; flex-wrap: wrap; }

  /* CTA under event grid — left-aligned on the section rail, never floated right */
  .upcoming-cta { margin-top: 2rem; }
</style>
