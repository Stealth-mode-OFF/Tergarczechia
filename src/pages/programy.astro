---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import { formatDateRange, eventTypeLabel, isFutureOrOngoing } from '@/lib/format';

const path = (await getCollection('path')).sort((a, b) => a.data.level - b.data.level);
const events = (await getCollection('events'))
  .filter((e) => isFutureOrOngoing(e.data) || e.data.featured)
  .sort((a, b) => a.data.dateStart.getTime() - b.data.dateStart.getTime())
  .slice(0, 6);

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Programy', href: '/programy' },
];
---

<BaseLayout
  title="Programy a kurzy — Tergar Česko"
  description="Strukturované meditační kurzy Tergar: Anytime Anywhere Meditation, Joy of Living 1–3, Path of Liberation, retreaty a přenosy s Mingyurem Rinpočhem."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">Programy</p>
        <h1>Strukturované kurzy pro systematický postup.</h1>
        <p class="lead">
          Tergar nabízí navazující programy od úplných začátků až po pokročilou praxi Mahámudry.
          Kurzy můžete absolvovat online samostatně, s českou skupinou nebo přímo na retreatu s Rinpočhem.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <h2>Tři hlavní trasy</h2>
      <div class="tracks">
        <Card class="track">
          <h3>Joy of Living 1–3</h3>
          <p>Sekulární program. Uvědomění · Soucit · Moudrost. Otevřený pro začátečníky.</p>
          <a href="/cesta/02-jol1" class="track-link">Vstoupit do programu →</a>
        </Card>
        <Card class="track">
          <h3>Path of Liberation 1–5</h3>
          <p>Tradiční buddhistická cesta Mahámudry. Přípravné praxe (ngöndro) + pokročilé meditace.</p>
          <a href="/cesta/05-pol1" class="track-link">Vstoupit do programu →</a>
        </Card>
        <Card class="track">
          <h3>Vajrayana Online</h3>
          <p>Pokročilé vajrayánové praxe pro absolventy Path of Liberation. Vedeno přímo Mingyurem Rinpočhem.</p>
          <a href="/cesta/10-vajrayana" class="track-link">Více o programu →</a>
        </Card>
      </div>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <div class="upcoming-head">
        <h2>Nadcházející akce</h2>
        <Button href="/akce" variant="secondary">Všechny akce</Button>
      </div>
      <div class="upcoming">
        {events.map((e) => (
          <Card href={`/akce/${e.id}`} class="ev">
            <p class="date">{formatDateRange(e.data.dateStart, e.data.dateEnd)}</p>
            <h3>{e.data.title}</h3>
            <p class="desc">{e.data.description}</p>
            <div class="ev-meta">
              <Badge variant="outline">{eventTypeLabel(e.data.type)}</Badge>
              {e.data.free && <Badge variant="accent">Zdarma</Badge>}
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .head { max-width: 46rem; }
  .head h1 { margin-top: 1rem; margin-bottom: 1.25rem; text-wrap: balance; }
  .head .lead { font-size: 1.25rem; color: var(--ink-muted); max-width: 58ch; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }
  .tracks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) { .tracks { grid-template-columns: repeat(3, 1fr); } }
  .track h3 { font-size: 1.375rem; margin: 0 0 0.75rem; }
  .track p { color: var(--ink-muted); margin-bottom: 1rem; }
  .track-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9375rem;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }
  .upcoming-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .upcoming-head h2 { margin: 0; }
  .upcoming {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) { .upcoming { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .upcoming { grid-template-columns: repeat(3, 1fr); } }
  .ev h3 { font-size: 1.125rem; margin: 0.375rem 0 0.5rem; line-height: 1.3; }
  .ev .date { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--accent); margin: 0; }
  .ev .desc { color: var(--ink-muted); font-size: 0.9375rem; margin: 0 0 0.75rem; }
  .ev-meta { display: flex; gap: 0.375rem; flex-wrap: wrap; }
</style>
