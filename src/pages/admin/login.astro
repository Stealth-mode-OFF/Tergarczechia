---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getServerClient, isAdminEmail, supabaseConfig } from '@/lib/supabase';

const supabase = getServerClient(Astro.request, Astro.cookies);
const {
  data: { user },
} = await supabase.auth.getUser();

const returnTo = Astro.url.searchParams.get('returnTo') ?? '/keystatic';
const err = Astro.url.searchParams.get('error');
const deniedEmail = Astro.url.searchParams.get('denied');

// Already logged in and allowed? Skip the form.
if (user && isAdminEmail(user.email)) {
  return Astro.redirect(returnTo);
}
---

<BaseLayout
  title="Přihlášení — Tergar redakce"
  description="Přihlášení do redakčního systému Tergar Česko."
  noindex
  jsonLd={null}
>
  <main class="login-main">
    <div class="login-card">
      <p class="login-kicker">Tergar Česko · Redakce</p>
      <h1 class="login-title">Přihlášení</h1>
      <p class="login-lede">
        Redakce je přístupná pouze pro pozvané správce sanghy. Přihlaste se svým Google účtem,
        který máte uvedený v seznamu správců.
      </p>

      {err && (
        <p class="login-error" role="alert">
          {err === 'denied' && deniedEmail && (
            <>Účet <strong>{deniedEmail}</strong> není v seznamu správců. Napište Josefovi a zkuste to znovu.</>
          )}
          {err === 'oauth' && <>Autentizace selhala. Zkuste to prosím ještě jednou.</>}
          {err !== 'denied' && err !== 'oauth' && <>{err}</>}
        </p>
      )}

      <button type="button" id="login-google" class="login-btn">
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92c1.7-1.57 2.68-3.88 2.68-6.62Z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.83.86-3.04.86-2.34 0-4.32-1.58-5.03-3.7H.92v2.33A9 9 0 0 0 9 18Z"/>
          <path fill="#FBBC05" d="M3.97 10.71a5.4 5.4 0 0 1 0-3.43V4.95H.92a9 9 0 0 0 0 8.1l3.05-2.34Z"/>
          <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.34l2.58-2.58A9 9 0 0 0 9 0 9 9 0 0 0 .92 4.95L3.97 7.3C4.68 5.16 6.66 3.58 9 3.58Z"/>
        </svg>
        Přihlásit přes Google
      </button>

      <p class="login-fine">
        Nemáte přístup? Napište <a href="mailto:czech@tergar.org">czech@tergar.org</a>.
      </p>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ url: supabaseConfig.url, anonKey: supabaseConfig.anonKey, returnTo }}>
  import('@supabase/supabase-js').then(({ createClient }) => {
    const supa = createClient(url, anonKey);
    const btn = document.getElementById('login-google');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      btn.setAttribute('disabled', 'true');
      btn.textContent = 'Otevírám Google…';
      const origin = window.location.origin;
      const { error } = await supa.auth.signInWithOAuth({
        provider: 'google',
        options: {
          redirectTo: `${origin}/api/auth/callback?returnTo=${encodeURIComponent(returnTo)}`,
        },
      });
      if (error) {
        btn.removeAttribute('disabled');
        btn.textContent = 'Přihlásit přes Google';
        window.location.search = '?error=oauth';
      }
    });
  });
</script>

<style>
  .login-main {
    min-height: calc(100dvh - 80px);
    display: grid;
    place-items: center;
    padding: 2rem 1.25rem;
    background:
      radial-gradient(circle at 80% 0%, rgba(224, 160, 32, 0.12), transparent 55%),
      radial-gradient(circle at 12% 100%, rgba(32, 48, 112, 0.1), transparent 55%),
      var(--bg);
  }
  .login-card {
    width: 100%;
    max-width: 28rem;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: 0 30px 80px -50px rgba(32, 48, 112, 0.25);
  }
  .login-kicker {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .login-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 4vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .login-lede {
    color: var(--ink-muted);
    line-height: 1.55;
    margin: 0 0 1.75rem;
    max-width: 32ch;
  }
  .login-error {
    padding: 0.75rem 1rem;
    background: color-mix(in oklab, #B0353A 12%, transparent);
    color: #8C2A2E;
    border: 1px solid color-mix(in oklab, #B0353A 35%, transparent);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    margin: 0 0 1.25rem;
  }
  .login-error strong { font-weight: 600; }
  .login-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.875rem 1.25rem;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
    min-height: 48px;
  }
  .login-btn:hover:not(:disabled) {
    background: color-mix(in oklab, var(--ink) 88%, white 12%);
    transform: translateY(-1px);
  }
  .login-btn:disabled { opacity: 0.7; cursor: progress; }
  .login-btn svg { background: var(--bg); border-radius: 999px; padding: 1px; }
  .login-fine {
    margin: 1.5rem 0 0;
    font-size: 0.8125rem;
    color: var(--ink-soft);
    text-align: start;
  }
  .login-fine a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
