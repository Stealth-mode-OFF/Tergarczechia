---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import RegistrationForm from '@/components/events/RegistrationForm';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { formatDateRange, eventTypeLabel, audienceLabel } from '@/lib/format';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Akce', href: '/akce' },
  { label: d.title, href: `/akce/${entry.id}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: d.title,
  description: d.description,
  startDate: d.dateStart.toISOString(),
  endDate: (d.dateEnd ?? d.dateStart).toISOString(),
  eventAttendanceMode: d.type === 'online'
    ? 'https://schema.org/OnlineEventAttendanceMode'
    : d.type === 'hybridni'
      ? 'https://schema.org/MixedEventAttendanceMode'
      : 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: d.status === 'zrusena'
    ? 'https://schema.org/EventCancelled'
    : 'https://schema.org/EventScheduled',
  location: d.location?.address
    ? {
        '@type': 'Place',
        name: d.location.name ?? 'Tibet Open House',
        address: {
          '@type': 'PostalAddress',
          streetAddress: d.location.address,
          addressLocality: d.location.city ?? 'Praha',
          addressCountry: 'CZ',
        },
      }
    : {
        '@type': 'VirtualLocation',
        url: d.registrationUrl ?? 'https://tergarczechia.cz',
      },
  organizer: {
    '@type': 'Organization',
    name: 'Tergar Česko',
    url: 'https://tergarczechia.cz',
  },
  offers: {
    '@type': 'Offer',
    price: d.free ? '0' : d.price ?? 'Dle programu',
    priceCurrency: 'CZK',
    url: d.registrationUrl ?? '',
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title={`${d.title} — Akce`}
  description={d.description}
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        eyebrow={formatDateRange(d.dateStart, d.dateEnd)}
        title={d.title}
        lede={d.description}
        as="h1"
        class="ev-head"
      />
      <div class="ev-meta">
        <Badge variant="accent">{eventTypeLabel(d.type)}</Badge>
        {d.audience !== 'vsichni' && <Badge variant="outline">{audienceLabel(d.audience)}</Badge>}
        {d.free && <Badge variant="accent">Zdarma</Badge>}
        {d.status === 'skoncila' && <Badge variant="muted">Akce už proběhla</Badge>}
        {d.status === 'zrusena' && <Badge variant="outline">Zrušeno</Badge>}
      </div>
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      <article class="prose">
        {d.body && <div set:html={d.body} />}
      </article>

      {d.location?.address && (
        <aside class="ev-location panel panel-soft panel-pad">
          <h3 class="meta-heading">Místo</h3>
          <p>
            <strong>{d.location.name}</strong><br />
            {d.location.address}
          </p>
        </aside>
      )}

      {d.status === 'planovana' && (
        <>
          {d.registrationUrl ? (
            <div class="bottom-cta action-row">
              <Button href={d.registrationUrl} variant="primary" size="lg" external>Přihlásit se (Zenamu)</Button>
              <Button href="/akce" variant="ghost">← Všechny akce</Button>
            </div>
          ) : (
            <section class="reg-card" aria-labelledby="reg-heading">
              <h2 id="reg-heading" class="reg-heading">Přihláška</h2>
              <RegistrationForm client:only="react" eventId={entry.id} eventTitle={d.title} />
            </section>
          )}
        </>
      )}
    </Container>
  </Section>
</BaseLayout>

<style>
  .ev-head { margin-bottom: 1.5rem; }
  .ev-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .ev-location {
    margin-top: 2.5rem;
  }
  .ev-location p { margin: 0; color: var(--ink-muted); }
  .bottom-cta { margin-top: 3rem; }

  /* Registration card — editorial form card, left-aligned on section rail */
  .reg-card {
    margin-top: 2.5rem;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
  }
  .reg-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.6vw, 1.875rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.015em;
  }
  :global(.reg-lede) {
    font-family: var(--font-sans);
    color: var(--ink-muted);
    margin: 0 0 1.5rem;
    font-size: 1rem;
    line-height: 1.55;
  }
  :global(.reg-form) { display: flex; flex-direction: column; gap: 1rem; }
  :global(.reg-form .field) { display: flex; flex-direction: column; gap: 0.375rem; }
  :global(.reg-form label) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  :global(.reg-form .opt) { font-weight: 400; text-transform: none; letter-spacing: normal; }
  :global(.reg-form input),
  :global(.reg-form textarea) {
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.75rem 0.875rem;
    background: var(--bg);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    color: var(--ink);
    transition: border-color var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
    width: 100%;
    min-height: 44px;
  }
  :global(.reg-form textarea) { resize: vertical; min-height: 90px; line-height: 1.55; }
  :global(.reg-form input:focus),
  :global(.reg-form textarea:focus) {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 25%, transparent);
  }
  :global(.reg-form .hp) { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  :global(.reg-form .submit) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 0.875rem 1.5rem;
    background: var(--accent);
    color: var(--tergar-navy);
    border: 1px solid var(--accent);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
    min-height: 46px;
    margin-top: 0.25rem;
  }
  :global(.reg-form .submit:hover:not(:disabled)) {
    background: var(--accent-hover);
    color: #fff;
  }
  :global(.reg-form .submit:disabled) { opacity: 0.65; cursor: not-allowed; }
  :global(.reg-error) {
    color: #B0353A;
    font-size: 0.9375rem;
    margin: 0;
  }
  :global(.reg-privacy) {
    font-size: 0.75rem;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0.5rem 0 0;
    max-width: 60ch;
  }
  :global(.reg-success) {
    padding: 1rem 0;
  }
  :global(.reg-success h3) {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    margin: 0 0 0.5rem;
    color: var(--accent);
  }
  :global(.reg-success p) {
    color: var(--ink);
    margin: 0;
    line-height: 1.55;
  }
  :global(.reg-success a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
