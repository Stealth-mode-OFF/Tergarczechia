---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import EventFilter from '@/components/events/EventFilter';
import { formatDateRange, eventTypeLabel, audienceLabel } from '@/lib/format';

const events = (await getCollection('events')).sort(
  (a, b) => a.data.dateStart.getTime() - b.data.dateStart.getTime(),
);

const today = new Date();
today.setHours(0, 0, 0, 0);

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Akce', href: '/akce' },
];

const types = [
  { value: 'online', label: 'Online' },
  { value: 'prezencni', label: 'Prezenčně' },
  { value: 'prenos', label: 'Přenos' },
  { value: 'hybridni', label: 'Hybridní' },
];
const audiences = [
  { value: 'zacatecnici', label: 'Začátečníci' },
  { value: 'zkuseni', label: 'Zkušení' },
  { value: 'vsichni', label: 'Všichni' },
];
---

<BaseLayout
  title="Akce a retreaty — Tergar Česko"
  description="Kalendář meditačních retreatů, workshopů a přenosů s Mingyurem Rinpočhem. Filtrujte podle formátu a úrovně."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Akce"
        title="Retreaty, workshopy, přenosy."
        lede="Kalendář akcí — online i prezenčně, s českými učiteli i s přímým přenosem od Mingyura Rinpočheho."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Kalendář 2026"
        title="Filtrujte podle formátu a úrovně."
      />
      <EventFilter types={types} audiences={audiences} client:visible />

      <ul class="ef-list" aria-label="Seznam akcí">
        {events.map((e) => {
          const end = (e.data.dateEnd ?? e.data.dateStart).getTime();
          const isPast = end < today.getTime();
          const hiddenInitial = isPast;
          return (
            <li
              class={`ef-item ${isPast ? 'is-past' : ''}`}
              data-event
              data-type={e.data.type}
              data-audience={e.data.audience}
              data-end-ts={end}
              hidden={hiddenInitial}
            >
              <a href={`/akce/${e.id}`}>
                <div class="ef-date">{formatDateRange(e.data.dateStart, e.data.dateEnd)}</div>
                <div class="ef-body">
                  <h3>{e.data.title}</h3>
                  <p>{e.data.description}</p>
                  <div class="ef-tags">
                    <span class="tag">{eventTypeLabel(e.data.type)}</span>
                    {e.data.audience !== 'vsichni' && (
                      <span class="tag">{audienceLabel(e.data.audience)}</span>
                    )}
                    {e.data.free && <span class="tag tag-accent">Zdarma</span>}
                  </div>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
      <p id="ef-empty" class="ef-empty" hidden>Žádná akce pro zvolené filtry.</p>
    </Container>
  </Section>
</BaseLayout>

<style>
  /* Filter row — left-aligned, matches the section rail. Never justify-content center. */
  :global(.ef-controls) {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    justify-content: flex-start;
    padding: 1.25rem;
    background: var(--surface);
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
  }
  :global(.ef-group) { display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start; min-width: 0; }
  :global(.ef-label) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
  }
  :global(.ef-row) { display: flex; flex-wrap: wrap; gap: 0.375rem; align-items: center; }
  :global(.ef-chip) {
    background: transparent;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-pill);
    padding: 0.3125rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
  }
  :global(.ef-chip:hover) { color: var(--ink); }
  :global(.ef-chip.is-active) { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  :global(.ef-toggle) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--ink-muted);
    cursor: pointer;
  }
  @media (max-width: 640px) {
    :global(.ef-controls) {
      padding: 1rem;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    :global(.ef-group) {
      width: 100%;
    }
    :global(.ef-row) {
      flex-wrap: nowrap;
      overflow-x: auto;
      width: 100%;
      padding-bottom: 0.125rem;
      scrollbar-width: none;
    }
    :global(.ef-row::-webkit-scrollbar) { display: none; }
  }

  .ef-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  .ef-item { border-top: 1px solid var(--line); }
  .ef-item:last-child { border-bottom: 1px solid var(--line); }
  .ef-item a {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    color: inherit;
    text-decoration: none;
  }
  @media (max-width: 640px) { .ef-item a { grid-template-columns: 1fr; gap: 0.75rem; } }
  .ef-date {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent);
    padding-top: 0.25rem;
  }
  @media (max-width: 640px) {
    .ef-date {
      display: inline-flex;
      width: fit-content;
      padding: 0;
      font-size: 0.8125rem;
      letter-spacing: 0.08em;
      border-bottom: 1px solid color-mix(in oklab, var(--accent) 50%, transparent);
    }
  }
  .ef-body h3 { font-size: 1.375rem; margin: 0 0 0.5rem; }
  .ef-body p { color: var(--ink-muted); margin: 0 0 0.75rem; }
  .ef-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .ef-tags .tag {
    display: inline-flex;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
  }
  .ef-tags .tag-accent { background: var(--accent-soft); color: var(--accent-hover); border-color: transparent; }
  .ef-item.is-past { opacity: 0.55; }
  .ef-item.is-past .ef-body h3 { text-decoration: line-through; text-decoration-thickness: 1px; }
  /* Empty state sits on the same rail — no centered island */
  .ef-empty { color: var(--ink-muted); padding: 2rem 0; text-align: start; }
</style>
