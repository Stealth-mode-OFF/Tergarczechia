---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import EventFilter from '@/components/events/EventFilter';

const events = (await getCollection('events')).sort(
  (a, b) => a.data.dateStart.getTime() - b.data.dateStart.getTime(),
);

const serialized = events.map((e) => ({
  id: e.id,
  href: `/akce/${e.id}`,
  title: e.data.title,
  dateStart: e.data.dateStart.toISOString(),
  dateEnd: e.data.dateEnd?.toISOString(),
  type: e.data.type,
  audience: e.data.audience,
  description: e.data.description,
  free: e.data.free,
  status: e.data.status,
}));

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Akce', href: '/akce' },
];
---

<BaseLayout
  title="Akce a retreaty — Tergar Česko"
  description="Kalendář meditačních retreatů, workshopů a přenosů s Mingyurem Rinpočhem. Filtrujte podle formátu a úrovně."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">Akce</p>
        <h1>Retreaty, workshopy, přenosy.</h1>
        <p class="lead">
          Kalendář akcí — online i prezenčně, s českými učiteli i s přímým přenosem od Mingyura Rinpočheho.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <EventFilter events={serialized} client:only="react" />
    </Container>
  </Section>
</BaseLayout>

<style>
  .head { max-width: 44rem; }
  .head h1 { margin-top: 1rem; margin-bottom: 1.25rem; text-wrap: balance; }
  .head .lead { font-size: 1.25rem; color: var(--ink-muted); max-width: 56ch; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }

  :global(.ef-controls) {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    padding: 1.25rem;
    background: var(--surface);
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
  }
  :global(.ef-group) { display: flex; flex-wrap: wrap; gap: 0.375rem; align-items: center; }
  :global(.ef-label) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
    margin-right: 0.5rem;
  }
  :global(.ef-chip) {
    background: transparent;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-pill);
    padding: 0.3125rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
  }
  :global(.ef-chip:hover) { color: var(--ink); }
  :global(.ef-chip.is-active) { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  :global(.ef-toggle) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--ink-muted);
    cursor: pointer;
    margin-left: auto;
  }
  :global(.ef-list) { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  :global(.ef-item) { border-top: 1px solid var(--line); }
  :global(.ef-item:last-child) { border-bottom: 1px solid var(--line); }
  :global(.ef-item a) {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    color: inherit;
    text-decoration: none;
  }
  @media (max-width: 640px) { :global(.ef-item a) { grid-template-columns: 1fr; } }
  :global(.ef-date) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent);
    padding-top: 0.25rem;
  }
  :global(.ef-body h3) { font-size: 1.375rem; margin: 0 0 0.5rem; }
  :global(.ef-body p) { color: var(--ink-muted); margin: 0 0 0.75rem; }
  :global(.ef-tags) { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  :global(.ef-tags .tag) {
    display: inline-flex;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
  }
  :global(.ef-tags .tag-accent) { background: var(--accent-soft); color: var(--accent-hover); border-color: transparent; }
  :global(.ef-item.is-past) { opacity: 0.55; }
  :global(.ef-item.is-past :global(.ef-body h3)) { text-decoration: line-through; text-decoration-thickness: 1px; }
  :global(.ef-empty) { color: var(--ink-muted); padding: 2rem 0; text-align: center; }
</style>
