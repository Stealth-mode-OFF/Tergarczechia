---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import Quote from '@/components/ui/Quote.astro';
import Divider from '@/components/ui/Divider.astro';
import mingyurPortrait from '@/assets/mingyur-portrait.png';
import mingyurWaving from '@/assets/mingyur-waving.png';
import communityImage from '@/assets/community.png';
import { getCollection } from 'astro:content';
import { formatDateRange, formatDateShort, eventTypeLabel } from '@/lib/format';
import { csTypo } from '@/lib/cs-typo';

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = (await getCollection('events'))
  .filter((e) => (e.data.dateEnd ?? e.data.dateStart) >= today)
  .sort((a, b) => a.data.dateStart.getTime() - b.data.dateStart.getTime());

const groups = (await getCollection('groups')).filter((g) => g.data.active);
const featuredEvent = upcoming[0];
const calendarPeek = upcoming.slice(1, 4);

const cityCount = new Set(groups.filter((g) => g.data.city !== 'Online').map((g) => g.data.city)).size;
const onlineCount = groups.filter((g) => g.data.city === 'Online').length;
const upcomingCount = upcoming.length;

const heroTitle = 'Meditace, která se hodí do českého života.';
const heroLede = 'Jsme česká pobočka meditační komunity Tergar vedená Yongey Mingyur Rinpočhem. Učíme dech, uvědomění, soucit — od prvních kroků až po pokročilou praxi.';

const audienceSegments = [
  {
    label: 'Jsem tu poprvé',
    title: 'Začínám s meditací',
    body: 'Projděte krátkou trasu „Co je meditace" a zkuste první vedenou praxi. Bez zkušeností. Bez vybavení. Bez nároků.',
    cta: { label: 'Začít', href: '/meditace' },
  },
  {
    label: 'Chci prohloubit',
    title: 'Pokračuji na cestě',
    body: 'Prohlédněte si Cestu Tergar — Joy of Living 1–3 a Path of Liberation. Strukturovaný program od tradice přes současnou vědu.',
    cta: { label: 'Cesta Tergar', href: '/cesta' },
  },
  {
    label: 'Hledám komunitu',
    title: 'Najdu si skupinu',
    body: 'V Praze, Českých Budějovicích, České Lípě i online. Pravidelná setkání každý týden — přijďte kdykoliv.',
    cta: { label: 'Skupiny', href: '/skupiny' },
  },
];

const pathHighlights = [
  { num: '01', title: 'Anytime Anywhere Meditation', sub: 'Úvod do meditace kdykoliv a kdekoliv' },
  { num: '02', title: 'Joy of Living 1–3', sub: 'Klid · soucit · moudrost' },
  { num: '03', title: 'Path of Liberation 1–5', sub: 'Tradiční cesta Mahámudry' },
  { num: '04', title: 'Vajrayana Online', sub: 'Pokročilá praxe pod vedením Rinpočheho' },
];
---

<BaseLayout
  title="Tergar Česko — Meditační komunita Yongey Mingyur Rinpočheho"
  description="Česká pobočka komunity Tergar pod vedením Yongey Mingyur Rinpočheho. Meditační program, skupiny po ČR, kalendář 2026."
  jsonLd="home"
>
  <!-- Hero -->
  <section class="hero bg-dharma-radiance">
    <div class="hero-spotlight" aria-hidden="true"></div>
    <Container>
      <div class="hero-grid">
        <div class="hero-text">
          <p class="hero-kicker">
            <span class="kicker-mark" aria-hidden="true"></span>
            Vítejte v&nbsp;Tergar Czechia
          </p>
          <h1 class="hero-title">{heroTitle}</h1>
          <p class="hero-lede">{heroLede}</p>
          <div class="hero-cta">
            <Button href="/skupiny" variant="primary" size="lg">Najděte skupinu</Button>
            <Button href="/meditace" variant="secondary" size="lg">Co je meditace</Button>
          </div>
          <dl class="hero-meta">
            <div>
              <dt>Skupiny</dt>
              <dd>{cityCount} měst{onlineCount > 0 ? ` · ${onlineCount} online` : ''}</dd>
            </div>
            <div>
              <dt>Nadcházející akce</dt>
              <dd>{upcomingCount}</dd>
            </div>
            <div>
              <dt>Tradice</dt>
              <dd>Karma Kagjü</dd>
            </div>
          </dl>
        </div>
        <aside class="hero-portrait" aria-hidden="true">
          <div class="portrait-frame">
            <Image
              src={mingyurPortrait}
              alt=""
              widths={[320, 480, 640, 960]}
              sizes="(max-width: 768px) 0px, (max-width: 1200px) 38vw, 480px"
              loading="eager"
              class="portrait-img"
            />
            <div class="portrait-ring"></div>
            <div class="portrait-glow"></div>
          </div>
          <figcaption class="portrait-caption">
            <span class="portrait-name">Yongey Mingyur Rinpočhe</span>
            <span class="portrait-role">zakladatel Tergar</span>
          </figcaption>
        </aside>
      </div>
    </Container>
    <Divider variant="wave" class="hero-wave" />
  </section>

  <!-- Audience segments -->
  <Section size="md">
    <Container>
      <header class="seg-header">
        <p class="eyebrow">Kudy dál</p>
        <h2>Každý začíná jinde. Vyberte si, co vám sedí.</h2>
      </header>
      <div class="segments">
        {audienceSegments.map((s) => (
          <Card href={s.cta.href} class="segment" elevated>
            <Badge variant="accent" size="sm">{s.label}</Badge>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <span class="seg-cta">
              {s.cta.label}
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 8h10 M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Path ladder -->
  <Section size="md" surface>
    <Container>
      <div class="path-layout">
        <div class="path-head">
          <p class="eyebrow">Cesta Tergar</p>
          <h2>Strukturovaný program — od prvních vdechů po Mahámudru.</h2>
          <p class="path-lede">
            Navazující úrovně vyvinuté Mingyurem Rinpočhem propojují starodávnou tradici tibetského buddhismu s pozorností k tomu, jak dnes žijeme.
            Každý stupeň staví na předchozím.
          </p>
          <Button href="/cesta" variant="secondary">Celá cesta</Button>
        </div>
        <ol class="path-list">
          {pathHighlights.map((p) => (
            <li>
              <span class="path-num">{p.num}</span>
              <div>
                <h4>{p.title}</h4>
                <p>{p.sub}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </Container>
  </Section>

  <!-- Teacher cameo -->
  <Section size="md" tint="navy" class="teacher">
    <Container>
      <div class="teacher-grid">
        <figure class="teacher-figure">
          <Image
            src={mingyurWaving}
            alt="Yongey Mingyur Rinpočhe"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 60vw, 380px"
            loading="lazy"
            class="teacher-img"
          />
          <figcaption class="teacher-cap">
            <span class="teacher-name">Yongey Mingyur Rinpočhe</span>
            <span class="teacher-role">učitel linie Karma Kagjü · Tergar International</span>
          </figcaption>
        </figure>
        <div class="teacher-body">
          <p class="eyebrow">Váš učitel</p>
          <blockquote class="teacher-quote">
            „Skutečná meditace je způsob, jak se spřátelit se svou vlastní myslí. A nejlepší přítel je ten, kdo vás přijme přesně takové, jací jste."
          </blockquote>
          <p class="teacher-lede">
            Mingyur Rinpočhe spojuje tradiční tibetský buddhismus s moderní neurovědou. Jeho knihy vyšly ve dvaceti jazycích, komunita Tergar má žáky ve více než třiceti zemích.
          </p>
          <div class="teacher-cta">
            <Button href="/o-nas" variant="primary">O Rinpočhem i sanghe</Button>
            <a href="https://tergar.org/yongey-mingyur-rinpoche" target="_blank" rel="noopener" class="teacher-link">Tergar International ↗</a>
          </div>
        </div>
      </div>
    </Container>
  </Section>

    {featuredEvent && (
    <Section size="md">
      <Container>
        <div class="next-event">
          <div class="ne-left">
            <p class="eyebrow">Nejbližší akce</p>
            <h2>{featuredEvent.data.title}</h2>
            <p class="ne-meta">
              <Badge variant="outline">{eventTypeLabel(featuredEvent.data.type)}</Badge>
              <span>{formatDateRange(featuredEvent.data.dateStart, featuredEvent.data.dateEnd)}</span>
              {featuredEvent.data.free && (
                <>
                  <span class="dot">·</span>
                  <span>Zdarma</span>
                </>
              )}
            </p>
            <p class="ne-body">{featuredEvent.data.description}</p>
            <div class="ne-cta">
              <Button href={`/akce/${featuredEvent.id}`} variant="primary">Detail akce</Button>
              {featuredEvent.data.registrationUrl && (
                <Button href={featuredEvent.data.registrationUrl} variant="ghost" external>Přihlásit se</Button>
              )}
            </div>
          </div>
          {calendarPeek.length > 0 && (
            <aside class="ne-right" aria-label="Další události">
              <h3 class="ne-small">Také v kalendáři</h3>
              <ul>
                {calendarPeek.map((e) => (
                  <li>
                    <span>{formatDateShort(e.data.dateStart)}</span>
                    <a href={`/akce/${e.id}`}>{e.data.title}</a>
                  </li>
                ))}
              </ul>
              <a href="/akce" class="ne-more">Celý kalendář →</a>
            </aside>
          )}
        </div>
      </Container>
    </Section>
  )}

  <!-- Groups teaser -->
  <Section size="md" surface>
    <Container>
      <div class="groups-teaser">
        <div>
          <p class="eyebrow">Skupiny</p>
          <h2>Setkáváme se tam, kde žijete.</h2>
          <p class="groups-lede">
            Pravidelná setkání v Praze (česky i anglicky), Českých Budějovicích, České Lípě a online. Otevřená — přijďte, i když jste nikdy nemeditovali.
          </p>
          <Button href="/skupiny" variant="primary">Prohlédnout mapu skupin</Button>
        </div>
        <ul class="groups-list">
          <li><strong>Praha</strong><span>2. a 4. čtvrtek · 19:00</span></li>
          <li><strong>Prague (English)</strong><span>2nd &amp; 4th Thursday · 19:00</span></li>
          <li><strong>Č. Budějovice</strong><span>Každou neděli</span></li>
          <li><strong>Česká Lípa</strong><span>Každou středu</span></li>
          <li><strong>Online</strong><span>Každé pondělí</span></li>
        </ul>
      </div>
    </Container>
  </Section>

  <!-- Footer CTA: donate + newsletter -->
  <Section size="md">
    <Container>
      <div class="end-cta">
        <div>
          <h2>Podpořte českou sanghu.</h2>
          <p>Tergar Česko je nezisková komunita. Každý dar — jednorázový i pravidelný — udržuje skupiny, překlady a setkání.</p>
          <Button href="/daru" variant="primary" size="lg">Chci podpořit</Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3.5rem, 7vw, 6rem) 0;
    overflow: hidden;
  }
  .hero-spotlight {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 8%, rgba(32, 48, 112, 0.08), transparent 50%),
      radial-gradient(circle at 12% 110%, rgba(224, 160, 32, 0.20), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }
  .hero :global(.container-default) { position: relative; z-index: 1; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    padding-bottom: 5rem;
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: 4rem;
      padding-bottom: 6rem;
    }
  }
  .hero-text {
    max-width: 40rem;
  }

  /* Portrait frame */
  .hero-portrait {
    position: relative;
    display: none;
  }
  @media (min-width: 900px) {
    .hero-portrait { display: block; justify-self: end; max-width: 440px; width: 100%; }
  }
  .portrait-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 2rem;
    overflow: hidden;
    background: linear-gradient(160deg, var(--tergar-cream) 0%, #EFE6D8 100%);
    box-shadow:
      0 4px 12px rgba(32, 48, 112, 0.06),
      0 40px 80px -40px rgba(32, 48, 112, 0.32);
  }
  .portrait-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  .portrait-ring {
    position: absolute;
    inset: 0.75rem;
    border: 1px solid rgba(224, 160, 32, 0.4);
    border-radius: 1.5rem;
    pointer-events: none;
  }
  .portrait-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle at 30% 30%, rgba(224, 160, 32, 0.18), transparent 50%);
    pointer-events: none;
    mix-blend-mode: screen;
  }
  .portrait-caption {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: 1.25rem;
    padding-left: 0.5rem;
    font-family: var(--font-sans);
  }
  .portrait-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--tergar-navy);
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .portrait-role {
    font-size: 0.75rem;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--tergar-navy);
    background: rgba(246, 231, 200, 0.55);
    border: 1px solid rgba(224, 160, 32, 0.3);
    border-radius: var(--radius-pill);
    padding: 0.5rem 0.875rem;
    margin-bottom: 1.75rem;
  }
  .kicker-mark {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px rgba(224, 160, 32, 0.2);
  }
  .hero-title {
    font-size: var(--text-5xl);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 1.25rem;
    max-width: 22ch;
    text-wrap: balance;
  }
  .hero-lede {
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--ink-muted);
    max-width: 54ch;
    margin-bottom: 2rem;
    text-wrap: pretty;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    max-width: 36rem;
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
    margin: 0;
  }
  .hero-meta div { display: flex; flex-direction: column; gap: 0.25rem; }
  .hero-meta dt {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-soft);
  }
  .hero-meta dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink);
  }
  .hero-wave {
    color: var(--accent-soft);
    opacity: 0.65;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }
  .seg-header {
    max-width: 40rem;
    margin-bottom: 3rem;
  }
  .seg-header h2 { text-wrap: balance; }

  .segments {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .segments { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .segment {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem 1.75rem 1.5rem;
  }
  .segment h3 {
    font-size: 1.625rem;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .segment p { color: var(--ink-muted); margin: 0; flex: 1; }
  .seg-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: 0.5rem;
  }
  .segment:hover .seg-cta svg { transform: translateX(3px); }
  .seg-cta svg { transition: transform var(--dur-fast) var(--ease-out); }

  .path-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 960px) {
    .path-layout { grid-template-columns: 1fr 1.1fr; gap: 5rem; }
  }
  .path-head h2 { text-wrap: balance; margin-bottom: 1rem; }
  .path-lede { color: var(--ink-muted); max-width: 44ch; margin-bottom: 1.5rem; }
  .path-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--line);
  }
  .path-list li {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }
  .path-num {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent);
    letter-spacing: 0.06em;
  }
  .path-list h4 {
    font-size: 1.375rem;
    margin: 0 0 0.25rem;
    font-family: var(--font-serif);
    letter-spacing: -0.005em;
    line-height: 1.25;
    text-wrap: balance;
  }
  .path-list p { color: var(--ink-muted); margin: 0; font-size: 0.9375rem; }

  .next-event {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 900px) { .next-event { grid-template-columns: 1.6fr 1fr; gap: 4rem; } }
  .ne-left h2 { text-wrap: balance; margin-bottom: 1.25rem; }
  .ne-meta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }
  .ne-body { color: var(--ink-muted); max-width: 56ch; margin-bottom: 1.5rem; }
  .ne-cta { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .ne-right {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  .ne-small {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    margin: 0 0 1rem;
  }
  .ne-right ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .ne-right li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.75rem;
  }
  .ne-right li:last-child { border-bottom: 0; padding-bottom: 0; }
  .ne-right li span:first-child {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
  }
  .ne-right li a {
    color: var(--ink);
    text-decoration: none;
    transition: color .15s;
  }
  .ne-right li a:hover { color: var(--accent); }
  .ne-more {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .groups-teaser {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 900px) { .groups-teaser { grid-template-columns: 1.1fr 1fr; gap: 4rem; } }
  .groups-teaser h2 { text-wrap: balance; margin-bottom: 1rem; }
  .groups-lede { color: var(--ink-muted); max-width: 48ch; margin-bottom: 1.5rem; }
  .groups-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .groups-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
  }
  .groups-list li:last-child { border-bottom: 1px solid var(--line); }
  .groups-list strong { font-family: var(--font-serif); font-weight: 600; font-size: 1.0625rem; }
  .groups-list span { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--ink-muted); }

  .end-cta {
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;
  }
