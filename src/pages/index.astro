---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import Divider from '@/components/ui/Divider.astro';
import SocialIcon from '@/components/ui/SocialIcon.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import MobileActionBar from '@/components/ui/MobileActionBar.astro';
import mingyurPortrait from '@/assets/mingyur-portrait.png';
import mingyurWaving from '@/assets/mingyur-waving.png';
import communityImage from '@/assets/community.png';
import { getCollection } from 'astro:content';
import { formatDateRange, formatDateShort, eventTypeLabel } from '@/lib/format';

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = (await getCollection('events'))
  .filter((e) => (e.data.dateEnd ?? e.data.dateStart) >= today)
  .sort((a, b) => a.data.dateStart.getTime() - b.data.dateStart.getTime());

const groups = (await getCollection('groups')).filter((g) => g.data.active);
const featuredEvent = upcoming[0];
const calendarPeek = upcoming.slice(1, 4);

const cityCount = new Set(groups.filter((g) => g.data.city !== 'Online').map((g) => g.data.city)).size;
const onlineCount = groups.filter((g) => g.data.city === 'Online').length;
const upcomingCount = upcoming.length;
const groupsPreview = groups
  .slice()
  .sort((a, b) => Number(a.data.city === 'Online') - Number(b.data.city === 'Online') || a.data.city.localeCompare(b.data.city, 'cs'))
  .slice(0, 5);

const heroTitle = 'Meditační komunita Tergar v Česku.';
const heroLede = 'Česká sangha Yongey Mingyur Rinpočheho. Skupiny v Praze, Budějovicích, České Lípě a online. Přijďte si sednout — i když jste nikdy nemeditovali.';

const audienceSegments = [
  {
    label: 'Jsem tu poprvé',
    meta: '5 minut · bez účtu',
    title: 'Nikdy jsem nemeditoval',
    body: 'Přečtěte si, co meditace v Tergar tradici znamená, a zkuste pět minut s vedením. Žádný účet, žádné vybavení.',
    cta: { label: 'Zkusit pět minut', href: '/meditace' },
  },
  {
    label: 'Chci prohloubit',
    meta: 'Joy of Living · Path of Liberation',
    title: 'Mám za sebou první měsíce praxe',
    body: 'Strukturovaný program od Joy of Living 1 po Mahámudru. Absolvujete online, v české skupině nebo na retreatu s Rinpočhem.',
    cta: { label: 'Celá cesta', href: '/cesta' },
  },
  {
    label: 'Hledám komunitu',
    meta: `${cityCount} měst${onlineCount > 0 ? ` · ${onlineCount} online` : ''}`,
    title: 'Chci potkat ostatní',
    body: 'V Praze, Českých Budějovicích, České Lípě i online. Pravidelná setkání každý týden — přijďte kdykoliv.',
    cta: { label: 'Najít sanghu', href: '/skupiny' },
  },
];

const pathHighlights = [
  { num: '01', title: 'Anytime Anywhere Meditation', sub: 'Úvod do meditace kdykoliv a kdekoliv' },
  { num: '02', title: 'Joy of Living 1–3', sub: 'Devítidílný program o práci s myslí, emocemi a soucitem.' },
  { num: '03', title: 'Path of Liberation 1–5', sub: 'Přípravné praxe (ngöndro) a meditace Mahámudry.' },
  { num: '04', title: 'Vajrayana Online', sub: 'Pokročilá vajrajánová praxe přímo s Rinpočhem.' },
];

const voices = (await getCollection('testimonials'))
  .filter((t) => t.data.active)
  .sort((a, b) => a.data.order - b.data.order)
  .map((t) => ({
    quote: t.data.quote,
    name: t.data.name,
    meta: [t.data.city, t.data.practiceYears].filter(Boolean).join(' · '),
  }));
---

<BaseLayout
  title="Tergar Česko — Meditační komunita Yongey Mingyur Rinpočheho"
  description="Česká pobočka komunity Tergar pod vedením Yongey Mingyur Rinpočheho. Meditační program, skupiny po ČR, kalendář 2026."
  jsonLd="home"
>
  <!-- Hero -->
  <section class="hero sec bg-dharma-radiance">
    <div class="hero-spotlight" aria-hidden="true"></div>
    <svg class="hero-mandala" viewBox="0 0 600 600" aria-hidden="true" focusable="false">
      <g fill="none" stroke="currentColor" stroke-width="1">
        <circle cx="300" cy="300" r="120"/>
        <circle cx="300" cy="300" r="180"/>
        <circle cx="300" cy="300" r="240" stroke-dasharray="2 6"/>
        <circle cx="300" cy="300" r="290"/>
      </g>
    </svg>
    <Container>
      <div class="hero-grid">
        <div class="hero-text">
          <p class="hero-kicker">
            <span class="kicker-mark" aria-hidden="true"></span>
            Tergar Česko · od roku 2014
          </p>
          <h1 class="hero-title">{heroTitle}</h1>
          <p class="hero-lede">{heroLede}</p>
          <div class="hero-cta">
            <Button href="/meditace" variant="primary" size="lg">Začít zdarma</Button>
            <Button href="/skupiny" variant="secondary" size="lg">Najít skupinu</Button>
          </div>
          <dl class="hero-meta">
            <div>
              <dt>Skupiny</dt>
              <dd>{cityCount} měst{onlineCount > 0 ? ` · ${onlineCount} online` : ''}</dd>
            </div>
            <div>
              <dt>Nadcházející akce</dt>
              <dd>{upcomingCount}</dd>
            </div>
            <div>
              <dt>Tradice</dt>
              <dd>Karma Kagjü</dd>
            </div>
          </dl>
        </div>
        <aside class="hero-panel" aria-label="Vyberte si první krok">
          <div class="hero-panel-shell">
            <p class="hero-panel-kicker">Nejrychlejší další krok</p>
            <div class="hero-steps">
              <a href="/meditace" class="hero-step hero-step-primary">
                <strong>Vyzkoušet meditaci</strong>
                <span>Krátký úvod a prvních 5 minut praxe.</span>
              </a>
              <a href="/skupiny" class="hero-step">
                <strong>Najít skupinu</strong>
                <span>Praha, další města i online setkání.</span>
              </a>
              <a href={featuredEvent?.data.registrationUrl ?? (featuredEvent ? `/akce/${featuredEvent.id}` : '/akce')} class="hero-step">
                <strong>{featuredEvent ? 'Nejbližší akce' : 'Kalendář akcí'}</strong>
                <span>{featuredEvent ? featuredEvent.data.title : 'Retreaty, workshopy a přenosy.'}</span>
              </a>
            </div>
            <div class="hero-guide">
              <div class="hero-guide-media">
                <Image
                  src={mingyurPortrait}
                  alt=""
                  widths={[120, 180, 240]}
                  sizes="72px"
                  loading="eager"
                  class="hero-guide-img"
                />
              </div>
              <div class="hero-guide-copy">
                <span class="hero-guide-title">Vede Yongey Mingyur Rinpočhe</span>
                <span class="hero-guide-text">Tergar propojuje tradiční meditaci s jazykem, který je srozumitelný i pro úplné začátky.</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
    <Divider variant="wheel" class="hero-wheel" />
  </section>

  <!-- Audience segments -->
  <Section size="md">
    <Container>
      <header class="seg-header">
        <p class="eyebrow"><span class="folio">01.</span>Kudy dál</p>
        <h2>Každý začíná jinde. Vyberte si, co vám sedí.</h2>
      </header>
      <div class="segments">
        {audienceSegments.map((s, index) => (
          <Card href={s.cta.href} class="segment" elevated accent={index === 0}>
            <Badge variant="accent" size="sm">{s.label}</Badge>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <span class="segment-meta">{s.meta}</span>
            <span class="seg-cta">
              {s.cta.label}
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 8h10 M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  {featuredEvent && (
    <Section size="md">
      <Container>
        <div class="next-event">
          <div class="ne-left">
            <p class="eyebrow"><span class="folio">02.</span>Nejbližší akce</p>
            <h2>{featuredEvent.data.title}</h2>
            <p class="ne-meta">
              <Badge variant="outline">{eventTypeLabel(featuredEvent.data.type)}</Badge>
              <span>{formatDateRange(featuredEvent.data.dateStart, featuredEvent.data.dateEnd)}</span>
              {featuredEvent.data.free && (
                <>
                  <span class="dot">·</span>
                  <span>Zdarma</span>
                </>
              )}
            </p>
            <p class="ne-body">{featuredEvent.data.description}</p>
            <div class="ne-cta">
              {featuredEvent.data.registrationUrl && (
                <Button href={featuredEvent.data.registrationUrl} variant="primary" external>Přihlásit se</Button>
              )}
              <Button href={`/akce/${featuredEvent.id}`} variant={featuredEvent.data.registrationUrl ? 'secondary' : 'primary'}>Detail akce</Button>
            </div>
          </div>
          {calendarPeek.length > 0 && (
            <aside class="ne-right" aria-label="Další události">
              <h3 class="ne-small">Také v kalendáři</h3>
              <ul>
                {calendarPeek.map((e) => (
                  <li>
                    <span>{formatDateShort(e.data.dateStart)}</span>
                    <a href={`/akce/${e.id}`}>{e.data.title}</a>
                  </li>
                ))}
              </ul>
              <a href="/akce" class="ne-more">Celý kalendář →</a>
            </aside>
          )}
        </div>
      </Container>
    </Section>
  )}

  <!-- Groups teaser -->
  <Section size="md" surface>
    <Container>
      <div class="groups-teaser">
        <div>
          <p class="eyebrow"><span class="folio">03.</span>Skupiny</p>
          <h2>Setkáváme se tam, kde žijete.</h2>
          <p class="groups-lede">
            Pravidelná setkání v Praze, Českých Budějovicích, České Lípě a online. Otevřená — přijďte, i když jste nikdy nemeditovali.
          </p>
          <Button href="/skupiny" variant="primary">Prohlédnout mapu skupin</Button>
        </div>
        <ul class="groups-list">
          {groupsPreview.map((group) => (
            <li>
              <strong>{group.data.city}</strong>
              <span class="groups-list-name">{group.data.name}</span>
              <span class="groups-list-schedule">{group.data.schedule}</span>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </Section>

  <!-- Hlasy sanghy -->
  <Section size="md" class="voices">
    <Container>
      <header class="voices-head">
        <p class="eyebrow"><span class="folio">04.</span>Hlasy sanghy</p>
        <h2>Praxe není teorie. Čtěte, proč zůstali.</h2>
      </header>
      <div class="voices-grid">
        {voices.map((v, i) => (
          <figure class={`voice voice-${i + 1}`}>
            <svg class="voice-mark" viewBox="0 0 24 18" fill="none" aria-hidden="true">
              <path d="M0 18V9C0 4 3 0 8 0v3c-2.5 0-4 2-4 5h4v10H0Zm13 0V9c0-5 3-9 8-9v3c-2.5 0-4 2-4 5h4v10h-8Z" fill="currentColor"/>
            </svg>
            <blockquote>
              <p>{v.quote}</p>
            </blockquote>
            <figcaption>
              <cite class="voice-name">{v.name}</cite>
              <span class="voice-meta">{v.meta}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Teacher cameo -->
  <Section size="md" tint="navy" class="teacher">
    <Container>
      <div class="teacher-grid">
        <figure class="teacher-figure">
          <Image
            src={mingyurWaving}
            alt="Yongey Mingyur Rinpočhe"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 60vw, 380px"
            loading="lazy"
            class="teacher-img"
          />
          <figcaption class="teacher-cap">
            <span class="teacher-name">Yongey Mingyur Rinpočhe</span>
            <span class="teacher-role">učitel linie Karma Kagjü · Tergar International</span>
          </figcaption>
        </figure>
        <div class="teacher-body">
          <p class="eyebrow"><span class="folio">05.</span>Váš učitel</p>
          <blockquote class="teacher-quote">
            <span class="big-quote" aria-hidden="true">„</span>
            Skutečná meditace je způsob, jak se spřátelit se svou vlastní myslí. A nejlepší přítel je ten, kdo vás přijme přesně takové, jací jste."
            <cite class="teacher-sig">— Yongey Mingyur Rinpočhe</cite>
          </blockquote>
          <p class="teacher-lede">
            Mingyur Rinpočhe spojuje tradiční tibetský buddhismus s moderní neurovědou. Jeho knihy vyšly ve dvaceti jazycích, komunita Tergar má žáky ve více než třiceti zemích.
          </p>
          <div class="teacher-cta">
            <Button href="/o-nas" variant="primary">O Rinpočhem i sanghe</Button>
            <a href="https://tergar.org/yongey-mingyur-rinpoche" target="_blank" rel="noopener" class="teacher-link">Tergar International ↗</a>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Path ladder -->
  <Section size="md" surface>
    <Container>
      <div class="path-layout">
        <div class="path-head">
          <p class="eyebrow"><span class="folio">06.</span>Cesta Tergar</p>
          <h2>Strukturovaný program — od prvních vdechů po Mahámudru.</h2>
          <p class="path-lede">
            Navazující úrovně vyvinuté Mingyurem Rinpočhem propojují starodávnou tradici tibetského buddhismu s pozorností k tomu, jak dnes žijeme.
            Každý stupeň staví na předchozím.
          </p>
          <Button href="/cesta" variant="secondary">Celá cesta</Button>
        </div>
        <ol class="path-list">
          {pathHighlights.map((p) => (
            <li>
              <span class="path-num">{p.num}</span>
              <div>
                <h4>{p.title}</h4>
                <p>{p.sub}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </Container>
  </Section>

  <!-- Instagram — community visuals + follow CTA -->
  <Section size="md" class="ig-section">
    <Container>
      <div class="ig-wrap">
        <header class="ig-head">
          <p class="eyebrow"><span class="folio">07.</span>Instagram</p>
          <h2>Sangha na fotkách.</h2>
          <p class="ig-lede">
            Setkání v Tibet Open House, retreaty v přírodě, učitelé navštěvující Česko. Sledujte každodenní život české sanghy na Instagramu.
          </p>
        </header>
        <a href="https://instagram.com/tergar_cz" target="_blank" rel="noopener" class="ig-grid" aria-label="Otevřít Instagram Tergar Česko">
          <div class="ig-tile ig-tile-1"><Image src={communityImage} alt="" widths={[240, 360]} sizes="(max-width: 768px) 33vw, 200px" loading="lazy" /></div>
          <div class="ig-tile ig-tile-2"><Image src={mingyurWaving} alt="" widths={[240, 360]} sizes="(max-width: 768px) 33vw, 200px" loading="lazy" /></div>
          <div class="ig-tile ig-tile-3"><Image src={mingyurPortrait} alt="" widths={[240, 360]} sizes="(max-width: 768px) 33vw, 200px" loading="lazy" /></div>
          <div class="ig-tile ig-tile-4 ig-tile-cta">
            <SocialIcon platform="instagram" variant="mono" size={30} />
            <span class="ig-cta-label">@tergar_cz</span>
            <span class="ig-cta-sub">Sledujte nás &#8599;</span>
          </div>
        </a>
        <div class="ig-follow-row">
          <a href="https://instagram.com/tergar_cz" target="_blank" rel="noopener" class="ig-follow ig-follow-ig">
            <SocialIcon platform="instagram" variant="brand" size={20} />
            Instagram
          </a>
          <a href="https://www.facebook.com/tergarcz/" target="_blank" rel="noopener" class="ig-follow ig-follow-fb">
            <SocialIcon platform="facebook" variant="brand" size={20} />
            Facebook
          </a>
          <a href="https://www.youtube.com/@tergarczechia1847" target="_blank" rel="noopener" class="ig-follow ig-follow-yt">
            <SocialIcon platform="youtube" variant="brand" size={20} />
            YouTube
          </a>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Footer CTA: donate + newsletter -->
  <Section size="md">
    <Container>
      <div class="end-cta">
        <SectionHeader
          folio="08"
          eyebrow="Podpořte"
          title="Podpořte českou sanghu."
          lede="Tergar Česko je nezisková komunita. Každý dar — jednorázový i pravidelný — udržuje skupiny, překlady a setkání."
        />
        <Button href="/daru" variant="primary" size="lg">Chci podpořit</Button>
      </div>
    </Container>
  </Section>

  <MobileActionBar
    label="Rychlé akce na domovské stránce"
    actions={[
      { label: 'Začít zdarma', href: '/meditace' },
      { label: 'Najít skupinu', href: '/skupiny', variant: 'secondary' },
    ]}
  />
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3.5rem, 7vw, 6rem) 0;
    overflow: hidden;
  }
  .hero-spotlight {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 8%, rgba(32, 48, 112, 0.08), transparent 50%),
      radial-gradient(circle at 12% 110%, rgba(224, 160, 32, 0.20), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }
  .hero :global(.container-default) { position: relative; z-index: 1; }

  /* Mandala backdrop — desktop only; on mobile it crowds the text
     and reads as noise. Mobile hero stays clean. */
  .hero-mandala { display: none; }
  @media (min-width: 960px) {
    .hero-mandala {
      display: block;
      position: absolute;
      top: -140px;
      right: -120px;
      width: 640px;
      height: 640px;
      color: var(--accent);
      opacity: 0.22;
      pointer-events: none;
      z-index: 0;
      mask-image: radial-gradient(circle at 50% 50%, black 30%, transparent 72%);
      -webkit-mask-image: radial-gradient(circle at 50% 50%, black 30%, transparent 72%);
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-mandala { animation: mandala-drift 60s linear infinite; }
  }
  @keyframes mandala-drift {
    to { transform: rotate(360deg); }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-md);
    align-items: center;
    padding-bottom: var(--section-md, 8rem);
  }
  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--gap-lg);
    }
  }
  .hero-text {
    max-width: 40rem;
  }
  .hero-panel {
    justify-self: stretch;
  }
  @media (min-width: 960px) {
    .hero-panel {
      justify-self: end;
      max-width: 30rem;
      width: 100%;
    }
  }
  .hero-panel-shell {
    display: grid;
    gap: 1rem;
    padding: clamp(1.125rem, 2.2vw, 1.5rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(246, 231, 200, 0.28)),
      color-mix(in oklab, var(--bg) 90%, white 10%);
    border: 1px solid color-mix(in oklab, var(--line-strong) 80%, white 20%);
    border-radius: 1.5rem;
    box-shadow:
      0 12px 30px -24px rgba(28, 43, 58, 0.45),
      0 24px 50px -42px rgba(224, 160, 32, 0.55);
    backdrop-filter: saturate(1.05) blur(10px);
    -webkit-backdrop-filter: saturate(1.05) blur(10px);
  }
  .hero-panel-kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
  }
  .hero-steps {
    display: grid;
    gap: 0.75rem;
  }
  .hero-step {
    display: grid;
    gap: 0.25rem;
    padding: 1rem 1.05rem;
    border-radius: 1rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.7);
    color: inherit;
    text-decoration: none;
    transition:
      transform var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }
  .hero-step:hover {
    transform: translateY(-1px);
    border-color: color-mix(in oklab, var(--accent) 72%, white 28%);
    box-shadow: 0 12px 28px -24px rgba(28, 43, 58, 0.45);
  }
  .hero-step strong {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--tergar-navy);
  }
  .hero-step span {
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--ink-muted);
  }
  .hero-step-primary {
    background: linear-gradient(145deg, rgba(246, 231, 200, 0.96), rgba(255, 250, 242, 0.98));
    border-color: color-mix(in oklab, var(--accent) 52%, white 48%);
  }
  .hero-guide {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.875rem;
    align-items: center;
    padding-top: 0.25rem;
    border-top: 1px solid color-mix(in oklab, var(--line) 82%, white 18%);
  }
  .hero-guide-media {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(160deg, var(--tergar-cream) 0%, #EFE6D8 100%);
    box-shadow:
      0 8px 18px -14px rgba(28, 43, 58, 0.4),
      0 14px 26px -22px rgba(224, 160, 32, 0.45);
  }
  .hero-guide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  .hero-guide-copy {
    display: grid;
    gap: 0.18rem;
  }
  .hero-guide-title {
