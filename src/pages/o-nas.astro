---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Quote from '@/components/ui/Quote.astro';
import Divider from '@/components/ui/Divider.astro';
import Card from '@/components/ui/Card.astro';
import { Image } from 'astro:assets';
import mingyurPortrait from '@/assets/mingyur-portrait.png';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'O nás', href: '/o-nas' },
];
---

<BaseLayout
  title="O nás — Tergar Česko"
  description="Česká pobočka mezinárodní meditační komunity Tergar. Učíme meditaci v tradici Karma Kagjü pod vedením Yongey Mingyur Rinpočheho."
  jsonLd={null}
  breadcrumbs={breadcrumbs}
>
  <Section size="sm">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="O nás"
        title="Česká sangha Tergar."
        lede="Dobrovolný spolek založený 2014. Učíme meditaci v tradici Yongey Mingyur Rinpočheho — bez poplatků, bez členství, bez mystifikace."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Učitel"
        title="Yongey Mingyur Rinpočhe"
        lede="Tibetský lama, syn Tulku Urgjena Rinpočheho. Autor knihy Radost ze života (vydala Maitrea). Jeho učení stojí na jednom postřehu: meditovat znamená poznávat vlastní mysl."
      />
      <div class="split-grid">
        <div>
          <p>
            Vede mezinárodní síť Tergar a řadu neziskových organizací. Jeho přístup propojuje staletou tradici s poznatky neurovědy.
            V laboratoři Richarda Davidsona na University of Wisconsin ukázal, jak meditace měřitelně mění mozek — nejen u mnichů, ale i u začátečníků.
          </p>
          <ul class="books lined-list">
            <li>Radost ze života — Štěstí jako vědecká disciplína</li>
            <li>Proměňte svůj život v meditaci</li>
            <li>Zamilovanost do světa — Mnichovo putování za moudrostí</li>
            <li>Vzhůru! — Odhalte sílu, bdělost a vnitřní klid</li>
          </ul>
        </div>
        <figure class="teacher-figure">
          <Image
            src={mingyurPortrait}
            alt="Yongey Mingyur Rinpočhe"
            widths={[480, 720, 1080]}
            sizes="(max-width: 768px) 90vw, 520px"
            format="avif"
            quality={82}
          />
        </figure>
      </div>
    </Container>
  </Section>

  <Section size="sm" class="about-quote">
    <Container size="prose">
      <Quote author="Mingyur Rinpočhe">
        „Problém není v tom, že máme emoce. Problém je v tom, že si myslíme, že bychom je mít neměli."
      </Quote>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Linie"
        title="Karma Kagjü — živá tradice."
        lede="Mingyur Rinpočhe je držitelem linie Karma Kagjü, jedné z hlavních škol tibetského buddhismu. Nepřerušená linie sahá od historického Buddhy přes indické mahásiddhy, tibetské mistry Marpu a Milarepu až po současné učitele."
      />
      <div class="split-grid is-reverse">
        <figure class="lineage-figure">
          <img
            src="/brand/infographic-lineage.svg"
            alt="Zkrácená vizuální linie Karma Kagjü — Buddha, mahásiddhové, tibetští mistři, Karmapové, Tulku Urgyen a Yongey Mingyur Rinpočhe"
            loading="lazy"
          />
        </figure>
        <div>
          <p>
            Mingyur Rinpočhe je žákem svého otce Tulku Urgjena Rinpočheho. Hlavou linie je XVII. Karmapa Ogjen Trinlä Dordžä.
            Tradice klade důraz na praxi vhledu (Mahámudra), laskavou přítomnost a přenos „od srdce k srdci".
          </p>
          <Button href="/cesta" variant="secondary">Cesta Tergar</Button>
        </div>
      </div>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="04"
        eyebrow="Co děláme"
        title="Čtyři věci, které děláme pravidelně."
      />
      <div class="cards-2 mission-list">
        <Card class="mission-card">
          <h3>Skupiny a setkání</h3>
          <p>Pravidelná týdenní meditace v Praze (česky i anglicky), Českých Budějovicích, České Lípě a online — otevřená všem.</p>
        </Card>
        <Card class="mission-card">
          <h3>Kurzy a workshopy</h3>
          <p>Anytime Anywhere Meditation, Joy of Living a přenosy retreatů s Mingyurem Rinpočhem — online i prezenčně v Tibet Open House.</p>
        </Card>
        <Card class="mission-card">
          <h3>Překlady a obsah</h3>
          <p>Překládáme Joy of Living do češtiny, točíme audio meditace, píšeme články a udržujeme slovník buddhistických pojmů.</p>
        </Card>
        <Card class="mission-card">
          <h3>Podpora Rinpočheho projektů</h3>
          <p>Posíláme 10 % vybraných darů do Tergar International. Dobrovolníci pomáhají při retreatech, překladech a live přenosech.</p>
        </Card>
      </div>
    </Container>
  </Section>

  <Divider variant="wave" class="ending-wave" />

  <Section size="md">
    <Container>
      <SectionHeader
        folio="05"
        eyebrow="Další krok"
        title="Nejjednodušší je přijít."
        lede="Druhé nejjednodušší je napsat. Skupiny jsou každý týden, e-mail odpovídá do tří dnů."
      />
      <div class="action-row end-cta">
        <Button href="/skupiny" variant="primary">Najděte skupinu</Button>
        <Button href="/kontakt" variant="ghost">Napište nám</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .split-grid p { color: var(--ink); max-width: 56ch; margin-bottom: 1rem; }
  .split-grid em { font-style: italic; }

  .books {
    margin: 1.25rem 0 0;
  }
  .books li {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink-muted);
  }
  .teacher-figure, .lineage-figure {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }
  .lineage-figure {
    max-width: 30rem;
  }
  .teacher-figure :global(img),
  .lineage-figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .mission-list {
    margin: 0;
    align-items: stretch;
  }
  .mission-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .mission-card h3 {
    font-size: 1.375rem;
    margin: 0;
    letter-spacing: -0.005em;
    line-height: 1.25;
    text-wrap: balance;
  }
  .mission-card p { color: var(--ink-muted); margin: 0; }
  @media (max-width: 767px) {
    .mission-card h3 {
      font-size: 1.25rem;
    }
  }

  .ending-wave { color: var(--accent-soft); margin-top: 2rem; }
  .about-quote :global(.quote) { margin-block: 0; }

</style>
