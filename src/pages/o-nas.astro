---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Quote from '@/components/ui/Quote.astro';
import Divider from '@/components/ui/Divider.astro';
import { Image } from 'astro:assets';
import mingyurPortrait from '@/assets/mingyur-portrait.png';
import lineageTree from '@/assets/lineage-tree.png';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'O nás', href: '/o-nas' },
];
---

<BaseLayout
  title="O nás — Tergar Česko"
  description="Česká pobočka mezinárodní meditační komunity Tergar. Učíme meditaci v tradici Karma Kagjü pod vedením Yongey Mingyur Rinpočheho."
  jsonLd={null}
  breadcrumbs={breadcrumbs}
>
  <Section size="sm">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="O nás"
        title="Česká sangha Tergar."
        lede="Jsme dobrovolná nezisková komunita, která na českém území rozvíjí učení Yongey Mingyur Rinpočheho. Spojujeme lidi, kteří chtějí meditaci začlenit do svého každodenního života — s otevřeností, prostou poctivostí a bez mystifikace."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Učitel"
        title="Yongey Mingyur Rinpočhe"
        lede="Tibetský buddhistický učitel a autor bestselleru Radost ze života. Známý svou vřelostí, humorem a schopností předat esenci meditační praxe lidem bez buddhistického zázemí."
      />
      <div class="grid-2">
        <div>
          <p>
            Vede mezinárodní síť Tergar a řadu neziskových organizací. Jeho přístup propojuje staletou tradici s poznatky neurovědy.
            V laboratoři Richarda Davidsona na University of Wisconsin ukázal, jak meditace měřitelně mění mozek — nejen u mnichů, ale i u začátečníků.
          </p>
          <ul class="books">
            <li>Radost ze života — Štěstí jako vědecká disciplína</li>
            <li>Proměňte svůj život v meditaci</li>
            <li>Zamilovanost do světa — Mnichovo putování za moudrostí</li>
            <li>Vzhůru! — Odhalte sílu, bdělost a vnitřní klid</li>
          </ul>
        </div>
        <figure class="teacher-figure">
          <Image
            src={mingyurPortrait}
            alt="Yongey Mingyur Rinpočhe"
            widths={[480, 720, 1080]}
            sizes="(max-width: 768px) 90vw, 520px"
            format="avif"
            quality={82}
          />
        </figure>
      </div>
    </Container>
  </Section>

  <Section size="sm" class="about-quote">
    <Container size="prose">
      <Quote author="Mingyur Rinpočhe">
        „Problém není v tom, že máme emoce. Problém je v tom, že si myslíme, že bychom je mít neměli."
      </Quote>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Linie"
        title="Karma Kagjü — živá tradice."
        lede="Mingyur Rinpočhe je držitelem linie Karma Kagjü, jedné z hlavních škol tibetského buddhismu. Nepřerušená linie sahá od historického Buddhy přes indické mahásiddhy, tibetské mistry Marpu a Milarepu až po současné učitele."
      />
      <div class="grid-2 reverse">
        <figure class="lineage-figure">
          <Image
            src={lineageTree}
            alt="Strom linie Karma Kagjü — od historického Buddhy k současným učitelům"
            widths={[480, 720, 1080]}
            sizes="(max-width: 768px) 90vw, 520px"
            format="avif"
            quality={82}
          />
        </figure>
        <div>
          <p>
            Mingyur Rinpočhe je žákem svého otce Tulku Urgjena Rinpočheho. Hlavou linie je XVII. Karmapa Ogjen Trinlä Dordžä.
            Tradice klade důraz na praxi vhledu (Mahámudra), laskavou přítomnost a přenos „od srdce k srdci".
          </p>
          <Button href="/cesta" variant="secondary">Cesta Tergar</Button>
        </div>
      </div>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="04"
        eyebrow="Co děláme"
        title="Česká pobočka globální sanghy."
      />
      <ul class="mission-list">
        <li>
          <h3>Skupiny a setkání</h3>
          <p>Pravidelná týdenní meditace v Praze (česky i anglicky), Českých Budějovicích, České Lípě a online — otevřená všem.</p>
        </li>
        <li>
          <h3>Kurzy a workshopy</h3>
          <p>Anytime Anywhere Meditation, Joy of Living a přenosy retreatů s Mingyurem Rinpočhem — online i prezenčně v Tibet Open House.</p>
        </li>
        <li>
          <h3>Překlady a obsah</h3>
          <p>Převádíme českou verzi Joy of Living, tvoříme články, audio meditace a slovník tibetsko-buddhistických pojmů.</p>
        </li>
        <li>
          <h3>Podpora Rinpočheho projektů</h3>
          <p>Česká sangha finančně i dobrovolnicky podporuje Tergar International, darujme.cz sbírky a lokální překlady.</p>
        </li>
      </ul>
    </Container>
  </Section>

  <Divider variant="wave" class="ending-wave" />

  <Section size="md">
    <Container>
      <SectionHeader
        folio="05"
        eyebrow="Přidejte se"
        title="Přidejte se, podpořte, přijďte."
        lede="Nejjednodušší krok je přijít na skupinu. Druhý nejjednodušší je napsat nám."
      />
      <div class="end-cta">
        <Button href="/skupiny" variant="primary">Najděte skupinu</Button>
        <Button href="/kontakt" variant="ghost">Napsat nám</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .grid-2.reverse > .lineage-figure { order: 2; }
  .grid-2.reverse > div { order: 1; }
  @media (min-width: 900px) {
    .grid-2 { grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center; }
    .grid-2.reverse { grid-template-columns: 0.9fr 1.1fr; }
    .grid-2.reverse > .lineage-figure { order: 1; }
    .grid-2.reverse > div { order: 2; }
  }
  .grid-2 p { color: var(--ink); max-width: 56ch; margin-bottom: 1rem; }
  .grid-2 em { font-style: italic; }

  .books {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .books li {
    padding: 0.5rem 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--line);
  }
  .teacher-figure, .lineage-figure {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }
  .lineage-figure {
    max-width: 30rem;
  }
  .teacher-figure :global(img),
  .lineage-figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .mission-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .mission-list { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  }
  .mission-list h3 {
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.005em;
    line-height: 1.25;
    text-wrap: balance;
  }
  .mission-list p { color: var(--ink-muted); margin: 0; }
  @media (max-width: 767px) {
    .mission-list li {
      padding-top: 1rem;
      border-top: 1px solid var(--line);
    }
    .mission-list li:first-child {
      padding-top: 0;
      border-top: 0;
    }
    .mission-list h3 {
      font-size: 1.25rem;
    }
  }

  .ending-wave { color: var(--accent-soft); margin-top: 2rem; }
  .about-quote :global(.quote) { margin-block: 0; }

  /* CTA row — left-aligned on all sizes to match the section rail */
  .end-cta { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: flex-start; }
</style>
