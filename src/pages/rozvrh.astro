---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import ConsentEmbed from '@/components/media/ConsentEmbed.tsx';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Rozvrh', href: '/rozvrh' },
];
---

<BaseLayout
  title="Rozvrh a přihláška — Tergar Česko"
  description="Aktuální rozvrh všech Tergar setkání, workshopů a retreatů v ČR. Přihlášení přes systém Zenamu."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Rozvrh"
        title="Rozvrh setkání."
        lede="Pravidelné skupiny, workshopy a retreaty v jednom kalendáři. Přihlášení vede přes Zenamu (externí systém)."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Kalendář"
        title="Pravidelné skupiny, workshopy, retreaty."
        lede="Načtením kalendáře souhlasíte s načtením obsahu z Zenamu. Aktualizuje se automaticky."
      />
      <ConsentEmbed
        src="https://app.zenamu.com/tergarczechia?view=schedule"
        title="Rozvrh a přihláška — Zenamu"
        provider="zenamu"
        aspect="1 / 1.1"
        client:visible
      />
      <p class="note">
        Technický systém: <a href="https://zenamu.com" target="_blank" rel="noopener noreferrer">Zenamu</a> —
        zobrazení rozvrhu vyžaduje načtení externího obsahu. Pokud ho nechcete načítat,
        otevřete rozvrh přímo v novém okně odkazem níže.
      </p>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Nenačítá se?"
        title="Zkuste obejít Zenamu."
        lede="Cookies, ad-blocker, slabé Wi-Fi — Zenamu to občas sundá. Hlavní informace najdete i u nás."
      />
      <div class="alt-cta action-row">
        <Button href="/akce" variant="primary">Kalendář akcí</Button>
        <Button href="/skupiny" variant="secondary">Pravidelné skupiny</Button>
        <Button href="https://app.zenamu.com/tergarczechia?view=schedule" variant="ghost" external>
          Zenamu v novém okně
        </Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .note { margin-top: 1rem; color: var(--ink-muted); font-size: 0.875rem; max-width: 60ch; }
  .note a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); padding-bottom: 1px; }
</style>
