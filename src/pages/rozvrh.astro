---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import ConsentEmbed from '@/components/media/ConsentEmbed.tsx';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Rozvrh', href: '/rozvrh' },
];
---

<BaseLayout
  title="Rozvrh a přihláška — Tergar Česko"
  description="Aktuální rozvrh všech Tergar setkání, workshopů a retreatů v ČR. Přihlášení přes systém Zenamu."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">Rozvrh</p>
        <h1>Přehled setkání a přihláška.</h1>
        <p class="lead">
          Kompletní aktuální rozvrh pravidelných skupin, workshopů a retreatů. Přihlašování probíhá přes externí systém Zenamu.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <h2 class="sr-only">Kalendář</h2>
      <ConsentEmbed
        src="https://app.zenamu.com/tergarczechia?view=schedule"
        title="Rozvrh a přihláška — Zenamu"
        provider="zenamu"
        aspect="1 / 1.1"
        client:visible
      />
      <p class="note">
        Technický systém: <a href="https://zenamu.com" target="_blank" rel="noopener noreferrer">Zenamu</a> —
        zobrazení rozvrhu vyžaduje načtení externího obsahu. Pokud ho nechcete načítat,
        otevřete rozvrh přímo v novém okně odkazem níže.
      </p>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <div class="alt">
        <div>
          <h2>Něco nevyšlo? Zkuste jeden z rychlých kroků.</h2>
          <p>
            Zenamu může selhat kvůli blokování cookies, ad-blockeru nebo jen protože vám nesedí.
            Většina potřebných informací je i u nás přímo na webu.
          </p>
        </div>
        <div class="alt-cta">
          <Button href="/akce" variant="primary">Kalendář akcí</Button>
          <Button href="/skupiny" variant="secondary">Pravidelné skupiny</Button>
          <Button href="https://app.zenamu.com/tergarczechia?view=schedule" variant="ghost" external>
            Zenamu v novém okně
          </Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
.note { margin-top: 1rem; color: var(--ink-muted); font-size: 0.875rem; max-width: 60ch; }
  .note a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); padding-bottom: 1px; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  .alt {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  @media (min-width: 800px) { .alt { grid-template-columns: 1.5fr 1fr; gap: 3rem; } }
  .alt h2 { text-wrap: balance; margin: 0 0 0.75rem; }
  .alt p { color: var(--ink-muted); margin: 0; max-width: 52ch; }
  .alt-cta { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: flex-end; }
  @media (max-width: 799px) { .alt-cta { justify-content: flex-start; } }
</style>
