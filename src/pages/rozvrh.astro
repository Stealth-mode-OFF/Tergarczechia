---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import ConsentEmbed from '@/components/media/ConsentEmbed.tsx';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Rozvrh', href: '/rozvrh' },
];
---

<BaseLayout
  title="Rozvrh a přihláška — Tergar Česko"
  description="Aktuální rozvrh všech Tergar setkání, workshopů a retreatů v ČR. Přihlášení přes systém Zenamu."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Rozvrh"
        title="Přehled setkání a přihláška."
        lede="Kompletní aktuální rozvrh pravidelných skupin, workshopů a retreatů. Přihlašování probíhá přes externí systém Zenamu."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Kalendář"
        title="Pravidelné skupiny, workshopy, retreaty."
        lede="Načtením kalendáře udělíte souhlas se stažením obsahu od Zenamu. Rozvrh se obnovuje automaticky."
      />
      <ConsentEmbed
        src="https://app.zenamu.com/tergarczechia?view=schedule"
        title="Rozvrh a přihláška — Zenamu"
        provider="zenamu"
        aspect="1 / 1.1"
        client:visible
      />
      <p class="note">
        Technický systém: <a href="https://zenamu.com" target="_blank" rel="noopener noreferrer">Zenamu</a> —
        zobrazení rozvrhu vyžaduje načtení externího obsahu. Pokud ho nechcete načítat,
        otevřete rozvrh přímo v novém okně odkazem níže.
      </p>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Něco nevyšlo?"
        title="Zkuste jeden z rychlých kroků."
        lede="Zenamu může selhat kvůli blokování cookies, ad-blockeru nebo jen protože vám nesedí. Většina potřebných informací je i u nás přímo na webu."
      />
      <div class="alt-cta">
        <Button href="/akce" variant="primary">Kalendář akcí</Button>
        <Button href="/skupiny" variant="secondary">Pravidelné skupiny</Button>
        <Button href="https://app.zenamu.com/tergarczechia?view=schedule" variant="ghost" external>
          Zenamu v novém okně
        </Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .note { margin-top: 1rem; color: var(--ink-muted); font-size: 0.875rem; max-width: 60ch; }
  .note a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); padding-bottom: 1px; }

  /* CTA row — always flush left to match section rail. No flex-end. */
  .alt-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: flex-start;
  }
</style>
