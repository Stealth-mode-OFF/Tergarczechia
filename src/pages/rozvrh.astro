---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ConsentEmbed from '@/components/media/ConsentEmbed.tsx';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Rozvrh', href: '/rozvrh' },
];
---

<BaseLayout
  title="Rozvrh a přihláška — Tergar Česko"
  description="Aktuální rozvrh všech Tergar setkání, workshopů a retreatů v ČR. Přihlášení přes systém Zenamu."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">Rozvrh</p>
        <h1>Přehled setkání a přihláška.</h1>
        <p class="lead">
          Kompletní aktuální rozvrh všech pravidelných skupin, workshopů a retreatů. Přihlašování probíhá přes externí systém Zenamu.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <ConsentEmbed
        src="https://app.zenamu.com/tergarczechia?view=schedule"
        title="Rozvrh a přihláška — Zenamu"
        provider="zenamu"
        aspect="1 / 1.1"
        client:visible
      />
      <p class="note">
        Technický systém: <a href="https://zenamu.com" target="_blank" rel="noopener noreferrer">Zenamu</a> —
        zobrazení rozvrhu vyžaduje načtení externího obsahu.
      </p>
    </Container>
  </Section>
</BaseLayout>

<style>
  .head { max-width: 44rem; }
  .head h1 { margin-top: 1rem; margin-bottom: 1.25rem; text-wrap: balance; }
  .head .lead { font-size: 1.25rem; color: var(--ink-muted); max-width: 56ch; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }
  .note { margin-top: 1rem; color: var(--ink-muted); font-size: 0.875rem; }
  .note a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); padding-bottom: 1px; }
</style>
