---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import GroupsMap from '@/components/groups/GroupsMap';
import MobileActionBar from '@/components/ui/MobileActionBar.astro';

const groups = (await getCollection('groups')).filter((g) => g.data.active);

const pins = groups.map((g) => ({
  id: g.id,
  name: g.data.name,
  city: g.data.city,
  schedule: g.data.schedule,
  lat: g.data.lat,
  lng: g.data.lng,
  color: g.data.color,
  href: g.data.registrationUrl ?? `mailto:${g.data.contactEmail ?? 'czech@tergar.org'}`,
}));

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Skupiny', href: '/skupiny' },
];
---

<BaseLayout
  title="Meditační skupiny — Tergar Česko"
  description="Pravidelná meditační setkání v Praze (česky i anglicky), Českých Budějovicích, České Lípě a online. Najděte skupinu poblíž vás."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Skupiny"
        title="Najděte sanghu poblíž sebe."
        lede="Každý týden. V Praze (česky i anglicky), Budějovicích, České Lípě a online. Není nutné se přihlašovat ani umět sedět v lotosu."
        as="h1"
      />
    </Container>
  </Section>

  <Section id="prehled-skupin" size="md" surface>
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Přehled skupin"
        title="Každý týden, bez přihlášky."
      />
      <ul class="group-list">
        {groups.map((g) => (
          <li class="group">
            <div class="group-marker" style={`--c: ${g.data.color ?? 'var(--accent)'}`} aria-hidden="true" />
            <div class="group-body">
              <h3>{g.data.name}</h3>
              <p class="group-where">
                <strong>{g.data.city}</strong>
                <span class="group-schedule">{g.data.schedule}</span>
              </p>
              {g.data.address && (
                <p class="group-addr">{g.data.address}</p>
              )}
              <div class="group-cta">
                {g.data.registrationUrl && (
                  <a href={g.data.registrationUrl} target="_blank" rel="noopener noreferrer" class="link-primary">
                    Přihlásit se (Zenamu) ↗
                  </a>
                )}
                {g.data.contactEmail && (
                  <a href={`mailto:${g.data.contactEmail}`} class="link-ghost">
                    {g.data.contactEmail}
                  </a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="03"
        eyebrow="Mapa skupin"
        title="Kde se potkáváme."
      />
      <div class="map-wrap">
        <GroupsMap groups={pins} client:only="react" />
      </div>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="04"
        eyebrow="Založte skupinu"
        title="Chybíme ve vašem městě?"
        lede="Pokud chcete začít pravidelné sezení v Olomouci, Ostravě, Plzni, Liberci, Hradci nebo jinde — ozvěte se. Pomůžeme se strukturou, materiály a první návštěvou z Prahy."
      />
      <Button href="/kontakt" variant="primary" size="lg">Napište nám</Button>
    </Container>
  </Section>

  <MobileActionBar
    label="Rychlé akce na stránce skupin"
    actions={[
      { label: 'Přehled skupin', href: '#prehled-skupin' },
      { label: 'Napište nám', href: '/kontakt', variant: 'secondary' },
    ]}
  />
</BaseLayout>

<style>
  .map-wrap { margin-top: 1rem; }

  .group-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-default);
  }
  @media (min-width: 960px) { .group-list { grid-template-columns: 1fr 1fr; } }
  .group {
    display: grid;
    grid-template-columns: 8px 1fr;
    gap: 1.25rem;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    background: var(--bg);
    border-radius: 14px;
    border: 1px solid var(--line);
  }
  .group-marker {
    --c: var(--accent);
    width: 4px;
    height: 100%;
    background: var(--c);
    border-radius: 2px;
  }
  .group h3 { font-size: 1.375rem; margin: 0 0 0.375rem; letter-spacing: -0.005em; line-height: 1.25; text-wrap: balance; }
  .group-where {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    margin: 0 0 0.5rem;
  }
  .group-where strong { color: var(--ink); font-weight: 600; }
  .group-schedule { color: var(--ink-muted); }
  .group-addr { font-size: 0.875rem; color: var(--ink-muted); white-space: pre-line; margin: 0 0 0.75rem; }
  .group-cta { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.875rem; }
  @media (max-width: 520px) {
    .group-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
  .link-primary {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    font-weight: 600;
  }
  .link-ghost {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1px;
  }
</style>
