---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import GroupsMap from '@/components/groups/GroupsMap';

const groups = (await getCollection('groups')).filter((g) => g.data.active);

const pins = groups.map((g) => ({
  id: g.id,
  name: g.data.name,
  city: g.data.city,
  schedule: g.data.schedule,
  lat: g.data.lat,
  lng: g.data.lng,
  color: g.data.color,
  href: g.data.registrationUrl ?? `mailto:${g.data.contactEmail ?? 'czech@tergar.org'}`,
}));

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Skupiny', href: '/skupiny' },
];
---

<BaseLayout
  title="Meditační skupiny — Tergar Česko"
  description="Pravidelná meditační setkání v Praze (česky i anglicky), Českých Budějovicích, České Lípě a online. Najděte skupinu poblíž vás."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">Skupiny</p>
        <h1>Najděte sanghu poblíž sebe.</h1>
        <p class="lead">
          Pravidelná týdenní meditace — otevřená všem, od začátečníků po dlouholeté praktikující.
          Není třeba se registrovat ani předem cokoliv umět. Přijďte tak, jak jste.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <div class="map-wrap">
        <GroupsMap groups={pins} client:only="react" />
      </div>
    </Container>
  </Section>

  <Section size="md" surface>
    <Container>
      <h2>Přehled skupin</h2>
      <ul class="group-list">
        {groups.map((g) => (
          <li class="group">
            <div class="group-marker" style={`--c: ${g.data.color ?? 'var(--accent)'}`} aria-hidden="true" />
            <div class="group-body">
              <h3>{g.data.name}</h3>
              <p class="group-where">
                <strong>{g.data.city}</strong>
                <span class="dot" aria-hidden="true">·</span>
                <span>{g.data.schedule}</span>
              </p>
              {g.data.address && (
                <p class="group-addr">{g.data.address}</p>
              )}
              <div class="group-cta">
                {g.data.registrationUrl && (
                  <a href={g.data.registrationUrl} target="_blank" rel="noopener noreferrer" class="link-primary">
                    Přihlásit se (Zenamu) ↗
                  </a>
                )}
                {g.data.contactEmail && (
                  <a href={`mailto:${g.data.contactEmail}`} class="link-ghost">
                    {g.data.contactEmail}
                  </a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <div class="start-group">
        <div>
          <p class="eyebrow">Založte skupinu</p>
          <h2>Ve vašem městě zatím nejsme — chcete to změnit?</h2>
          <p>
            Pokud byste chtěli být iniciátorem pravidelných setkání u vás (Olomouc, Ostrava, Plzeň, Liberec, Hradec, jinde),
            rádi vás podpoříme zkušenostmi, materiály a návštěvou.
          </p>
        </div>
        <Button href="/kontakt" variant="primary" size="lg">Napište nám</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
.map-wrap { margin-top: 1rem; }

  .group-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-default);
  }
  @media (min-width: 720px) { .group-list { grid-template-columns: 1fr 1fr; } }
  .group {
    display: grid;
    grid-template-columns: 8px 1fr;
    gap: 1.25rem;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    background: var(--bg);
    border-radius: 14px;
    border: 1px solid var(--line);
  }
  .group-marker {
    --c: var(--accent);
    width: 4px;
    height: 100%;
    background: var(--c);
    border-radius: 2px;
  }
  .group h3 { font-size: 1.375rem; margin: 0 0 0.375rem; letter-spacing: -0.005em; line-height: 1.25; text-wrap: balance; }
  .group-where {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    margin: 0 0 0.5rem;
  }
  .group-where strong { color: var(--ink); font-weight: 600; }
  .dot { color: var(--ink-soft); margin: 0 0.375rem; }
  .group-addr { font-size: 0.875rem; color: var(--ink-muted); white-space: pre-line; margin: 0 0 0.75rem; }
  .group-cta { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.875rem; }
  .link-primary {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }
  .link-ghost {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1px;
  }

  .start-group {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    padding: 2rem 0;
  }
  @media (min-width: 768px) { .start-group { grid-template-columns: 2fr 1fr; } }
  .start-group h2 { margin: 0.5rem 0 1rem; text-wrap: balance; }
  .start-group p { color: var(--ink-muted); margin: 0; max-width: 52ch; }
</style>
