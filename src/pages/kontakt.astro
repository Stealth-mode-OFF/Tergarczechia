---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<BaseLayout
  title="Kontakt — Tergar Česko"
  description="Kontaktní údaje Tergar Česko, adresa Tibet Open House v Praze, e-mail a odkazy na sociální sítě. Napište nám."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Kontakt"
        title="Napište nám."
        lede="Nejrychlejší je e-mail. Na zprávy obvykle odpovídáme do 2–3 dnů."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Obecné dotazy"
        title="Napište o čemkoliv."
      />
      <div class="split-grid kontakt-grid">
        <div class="k-main">
          <p class="email">
            <a href="mailto:czech@tergar.org">czech@tergar.org</a>
          </p>
          <p class="note">
            Napište nám o čemkoliv — registrace, dotaz k meditaci, nabídka pomoci, cokoliv.
          </p>

          <h3 class="meta-heading sub">Místo setkávání</h3>
          <address class="addr">
            <strong>Tibet Open House</strong><br />
            Školská 28<br />
            110 00 Praha 1<br />
            <a href="https://mapy.cz/zakladni?q=tibet+open+house" target="_blank" rel="noopener noreferrer" class="map-link link-inline">
              Otevřít v Mapy.cz ↗
            </a>
          </address>

          <h3 class="meta-heading sub">Sociální sítě</h3>
          <div class="chip-nav social">
            <a href="https://www.facebook.com/tergarcz/" target="_blank" rel="noopener noreferrer">Facebook</a>
            <a href="https://instagram.com/tergar_cz" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://www.youtube.com/@tergarczechia1847" target="_blank" rel="noopener noreferrer">YouTube</a>
          </div>
        </div>

        <aside class="k-side panel panel-soft panel-pad">
          <h3 class="meta-heading">Právní údaje</h3>
          <dl class="detail-grid">
            <dt>Právní forma</dt>
            <dd>Zapsaný spolek</dd>
            <dt>Název</dt>
            <dd>Tergar Czech z.s.</dd>
            <dt>IČO</dt>
            <dd>07412756</dd>
            <dt>Sídlo</dt>
            <dd>Chorvatská 12<br />101 00 Praha 10</dd>
          </dl>
        </aside>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .k-main .sub { margin: 2rem 0 0.75rem; }
  .email {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    margin: 0;
  }
  .email a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 0.2em; }
  .note { color: var(--ink-muted); margin: 0.5rem 0 0; }

  .addr {
    font-style: normal;
    line-height: 1.6;
    color: var(--ink);
  }
  .map-link { display: inline-block; margin-top: 0.375rem; font-size: 0.875rem; }
  .social { margin-top: 0.25rem; }
</style>
