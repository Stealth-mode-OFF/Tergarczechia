---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<BaseLayout
  title="Kontakt — Tergar Česko"
  description="Kontaktní údaje Tergar Česko, adresa Tibet Open House v Praze, e-mail a odkazy na sociální sítě. Napište nám."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">Kontakt</p>
        <h1>Napište nám.</h1>
        <p class="lead">
          Nejrychlejší je e-mail. Na zprávy obvykle odpovídáme do 2–3 dnů.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <div class="kontakt-grid">
        <div class="k-main">
          <h2>Obecné dotazy</h2>
          <p class="email">
            <a href="mailto:czech@tergar.org">czech@tergar.org</a>
          </p>
          <p class="note">
            Napište nám o čemkoliv — registrace, dotaz k meditaci, nabídka pomoci, cokoliv.
          </p>

          <h2 class="mt">Místo setkávání</h2>
          <address class="addr">
            <strong>Tibet Open House</strong><br />
            Školská 28<br />
            110 00 Praha 1<br />
            <a href="https://mapy.cz/zakladni?q=tibet+open+house" target="_blank" rel="noopener noreferrer" class="map-link">
              Otevřít v Mapy.cz ↗
            </a>
          </address>

          <h2 class="mt">Sociální sítě</h2>
          <ul class="social">
            <li><a href="https://www.facebook.com/tergarcz/" target="_blank" rel="noopener noreferrer">Facebook · tergarcz</a></li>
            <li><a href="https://instagram.com/tergar_cz" target="_blank" rel="noopener noreferrer">Instagram · tergar_cz</a></li>
            <li><a href="https://www.youtube.com/@tergarczechia1847" target="_blank" rel="noopener noreferrer">YouTube · tergarczechia</a></li>
          </ul>
        </div>

        <aside class="k-side">
          <h3>Právní údaje</h3>
          <dl>
            <dt>Právní forma</dt>
            <dd>Zapsaný spolek</dd>
            <dt>Název</dt>
            <dd>Tergar Czech z.s.</dd>
            <dt>IČO</dt>
            <dd>07412756</dd>
            <dt>Sídlo</dt>
            <dd>Chorvatská 12<br />101 00 Praha 10</dd>
          </dl>
        </aside>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
.kontakt-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 900px) { .kontakt-grid { grid-template-columns: 1.6fr 1fr; gap: 4rem; } }
  .k-main h2 { font-size: 1.5rem; margin: 0 0 0.75rem; letter-spacing: -0.005em; line-height: 1.25; text-wrap: balance; }
  .k-main h2.mt { margin-top: 2.5rem; }
  .email {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    margin: 0;
  }
  .email a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 0.2em; }
  .note { color: var(--ink-muted); margin: 0.5rem 0 0; }

  .addr {
    font-style: normal;
    line-height: 1.6;
    color: var(--ink);
  }
  .map-link {
    display: inline-block;
    margin-top: 0.375rem;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    font-size: 0.875rem;
  }
  .social { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .social a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--line); padding-bottom: 1px; }
  .social a:hover { color: var(--accent); border-color: var(--accent); }

  .k-side {
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    background: var(--surface);
    border-radius: 14px;
  }
  .k-side h3 {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  .k-side dl { display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1.25rem; margin: 0; }
  .k-side dt { color: var(--ink-muted); font-size: 0.8125rem; }
  .k-side dd { color: var(--ink); margin: 0; font-size: 0.9375rem; }
</style>
