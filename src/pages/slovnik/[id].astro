---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

export async function getStaticPaths() {
  const terms = await getCollection('glossary');
  return terms.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Slovník', href: '/slovnik' },
  { label: d.term, href: `/slovnik/${entry.id}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: d.term,
  alternateName: [d.termSanskrit, d.termTibetan].filter(Boolean),
  description: d.shortDef,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Slovník buddhistických pojmů — Tergar Česko',
    url: 'https://tergarczechia.cz/slovnik',
  },
};
---

<BaseLayout
  title={`${d.term} — Slovník · Tergar Česko`}
  description={d.shortDef}
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        eyebrow="Slovník"
        title={d.term}
        as="h1"
        class="head glossary-head"
      />
      <dl class="term-alt panel panel-soft panel-pad">
          {d.termSanskrit && (
            <div><dt>Sanskrt</dt><dd><em>{d.termSanskrit}</em></dd></div>
          )}
          {d.termTibetan && (
            <div><dt>Tibetština</dt><dd class="tib">{d.termTibetan}</dd></div>
          )}
          {d.pronunciation && (
            <div><dt>Výslovnost</dt><dd>{d.pronunciation}</dd></div>
          )}
      </dl>
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      <p class="short-def">{d.shortDef}</p>
      <hr />
      <article class="prose">
        <Content />
      </article>
      <div class="bottom-cta action-row">
        <Button href="/slovnik" variant="ghost">← Zpět na slovník</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
.glossary-head {
    margin-bottom: 1.5rem;
  }
  .glossary-head :global(.title) { font-size: clamp(2.5rem, 5vw, 3.75rem); }
  .term-alt {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
  }
  .term-alt div { display: flex; flex-direction: column; gap: 0.125rem; }
  .term-alt dt {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0;
  }
  .term-alt dd {
    margin: 0;
    font-size: 1.0625rem;
    color: var(--ink);
  }
  .term-alt dd em { font-style: italic; }
  .term-alt dd.tib { font-family: var(--font-serif); }

  .short-def {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }
  hr { border: 0; border-top: 1px solid var(--line); margin: 1.5rem 0 2.5rem; }
  .bottom-cta { margin-top: 3rem; }
</style>
