---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Accordion from '@/components/ui/Accordion.astro';

const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

const sections: Record<string, typeof faqs> = {};
for (const f of faqs) {
  if (!sections[f.data.section]) sections[f.data.section] = [];
  sections[f.data.section].push(f);
}

const sectionLabels: Record<string, string> = {
  obecne: 'Obecné',
  programy: 'Programy',
  meditace: 'Meditace',
  skupiny: 'Skupiny',
  daru: 'Daru',
};

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Časté dotazy', href: '/faq' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.data.answer,
    },
  })),
};

// Sequential folios — one per section plus the hero
const sectionKeys = Object.keys(sections);
---

<BaseLayout
  title="Časté dotazy — Tergar Česko"
  description="Odpovědi na nejčastější otázky k meditaci, programům, skupinám, darům. Musím být buddhista? Kolik to stojí? Jak dlouho meditovat?"
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="FAQ"
        title="Časté dotazy."
        lede="Odpovědi na to, co se nejčastěji ptáte. Pokud tady odpověď nenajdete, napište nám."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      {sectionKeys.map((key, idx) => (
        <div class="faq-section">
          <SectionHeader
            folio={String(idx + 2).padStart(2, '0')}
            eyebrow={sectionLabels[key] ?? key}
            title={`Otázky k tématu ${sectionLabels[key] ?? key}.`}
          />
          <div class="faq-list">
            {sections[key].map((f) => (
              <Accordion summary={f.data.question}>
                <p>{f.data.answer}</p>
              </Accordion>
            ))}
          </div>
        </div>
      ))}
    </Container>
  </Section>
</BaseLayout>

<style>
  .faq-section { margin-bottom: 3.5rem; }
  .faq-section:last-child { margin-bottom: 0; }
  .faq-list { margin-top: 1rem; }
  .faq-list p { white-space: pre-line; }
</style>
