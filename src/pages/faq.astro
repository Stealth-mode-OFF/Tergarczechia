---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Accordion from '@/components/ui/Accordion.astro';

const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

const sections: Record<string, typeof faqs> = {};
for (const f of faqs) {
  if (!sections[f.data.section]) sections[f.data.section] = [];
  sections[f.data.section].push(f);
}

const sectionLabels: Record<string, string> = {
  obecne: 'Obecné',
  programy: 'Programy',
  meditace: 'Meditace',
  skupiny: 'Skupiny',
  daru: 'Daru',
};

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Časté dotazy', href: '/faq' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.data.answer,
    },
  })),
};
---

<BaseLayout
  title="Časté dotazy — Tergar Česko"
  description="Odpovědi na nejčastější otázky k meditaci, programům, skupinám, darům. Musím být buddhista? Kolik to stojí? Jak dlouho meditovat?"
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="head">
        <p class="eyebrow">FAQ</p>
        <h1>Časté dotazy.</h1>
        <p class="lead">
          Odpovědi na to, co se nejčastěji ptáte. Pokud tady odpověď nenajdete, napište nám.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      {Object.entries(sections).map(([key, items]) => (
        <section class="faq-section">
          <h2>{sectionLabels[key] ?? key}</h2>
          <div class="faq-list">
            {items.map((f) => (
              <Accordion summary={f.data.question}>
                <p>{f.data.answer}</p>
              </Accordion>
            ))}
          </div>
        </section>
      ))}
    </Container>
  </Section>
</BaseLayout>

<style>
  .head { max-width: 44rem; }
  .head h1 { margin-top: 1rem; margin-bottom: 1.25rem; }
  .head .lead { font-size: 1.25rem; color: var(--ink-muted); max-width: 56ch; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }
  .faq-section { margin-bottom: 3rem; }
  .faq-section h2 {
    font-size: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
    display: inline-block;
    margin-bottom: 0.5rem;
  }
  .faq-list { margin-top: 1rem; }
  .faq-list p { white-space: pre-line; }
</style>
