---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Accordion from '@/components/ui/Accordion.astro';

const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

const sections: Record<string, typeof faqs> = {};
for (const f of faqs) {
  if (!sections[f.data.section]) sections[f.data.section] = [];
  sections[f.data.section].push(f);
}

const faqAnswerHtml = (answer: string) => {
  const escapeHtml = (value: string) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;');

  return answer
    .trim()
    .split(/\n{2,}/)
    .map((paragraph) => {
      const safe = escapeHtml(paragraph)
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br />');
      return `<p>${safe}</p>`;
    })
    .join('');
};

const sectionLabels: Record<string, string> = {
  obecne: 'Obecné',
  programy: 'Programy',
  meditace: 'Meditace',
  skupiny: 'Skupiny',
  daru: 'Daru',
};

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Časté dotazy', href: '/faq' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.data.answer,
    },
  })),
};

// Sequential folios — one per section plus the hero
const sectionKeys = Object.keys(sections);
---

<BaseLayout
  title="Časté dotazy — Tergar Česko"
  description="Odpovědi na nejčastější otázky k meditaci, programům, skupinám, darům. Musím být buddhista? Kolik to stojí? Jak dlouho meditovat?"
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Section size="sm">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="FAQ"
        title="Časté dotazy."
        lede="Odpovědi na to, co se nejčastěji ptáte. Pokud tady odpověď nenajdete, napište nám."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      {sectionKeys.map((key, idx) => (
        <div class="faq-section">
          <p class="faq-kicker">
            <span class="faq-folio">{String(idx + 2).padStart(2, '0')}.</span>
            <span>{sectionLabels[key] ?? key}</span>
          </p>
          <h2 class="faq-title">{sectionLabels[key] ?? key}</h2>
          <div class="faq-list">
            {sections[key].map((f) => (
              <Accordion summary={f.data.question}>
                <div class="faq-answer" set:html={faqAnswerHtml(f.data.answer)} />
              </Accordion>
            ))}
          </div>
        </div>
      ))}
    </Container>
  </Section>
</BaseLayout>

<style>
  .faq-section { margin-bottom: 3rem; }
  .faq-section:last-child { margin-bottom: 0; }
  .faq-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .faq-folio {
    color: var(--accent);
    padding-right: 0.625rem;
    border-right: 1px solid var(--line-strong);
  }
  .faq-title {
    margin: 0;
    font-size: clamp(1.875rem, 5vw, 2.5rem);
    line-height: 1.12;
  }
  .faq-title::after {
    content: '';
    display: block;
    width: 5rem;
    height: 2px;
    margin-top: 0.75rem;
    background: var(--accent);
  }
  .faq-list { margin-top: 1rem; }
  .faq-answer :global(strong) { color: var(--ink); font-weight: 700; }
  .faq-list :global(p + p) { margin-top: 0.875rem; }
</style>
