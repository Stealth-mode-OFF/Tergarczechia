---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import CategoryFilter from '@/components/blog/CategoryFilter';
import { formatDate, categoryLabel } from '@/lib/format';

const blog = (await getCollection('blog')).filter((a) => !a.data.draft);
const resources = await getCollection('resources');

type CardItem = {
  id: string;
  title: string;
  description: string;
  href: string;
  external: boolean;
  category: string;
  kind: string;
  kindLabel: string;
  date?: string;
  dateTs?: number;
  thumb?: string;
  youtubeId?: string;
  featured?: boolean;
};

const kindLabels: Record<string, string> = {
  blog: 'Článek',
  clanek: 'Článek',
  video: 'Video',
  kniha: 'Kniha',
  podcast: 'Podcast',
  'meditace-audio': 'Audio',
};

const items: CardItem[] = [
  ...blog.map((a): CardItem => ({
    id: a.id,
    title: a.data.title,
    description: a.data.perex,
    href: `/zdroje/${a.id}`,
    external: false,
    category: a.data.category,
    kind: 'blog',
    kindLabel: 'Článek',
    date: formatDate(a.data.date),
    dateTs: a.data.date.getTime(),
    thumb: a.data.thumbnailRemote,
    youtubeId: a.data.youtubeId,
    featured: a.data.featured,
  })),
  ...resources.map((r): CardItem => ({
    id: r.id,
    title: r.data.title,
    description: r.data.description,
    href: r.data.url
      ? r.data.url
      : r.data.youtubeId
        ? `https://www.youtube.com/watch?v=${r.data.youtubeId}`
        : '/kontakt',
    external: !!r.data.url || !!r.data.youtubeId,
    category: r.data.category,
    kind: r.data.kind,
    kindLabel: kindLabels[r.data.kind] ?? r.data.kind,
    date: r.data.publishedAt ? formatDate(r.data.publishedAt) : undefined,
    dateTs: r.data.publishedAt?.getTime(),
    thumb: r.data.thumbnailRemote,
    youtubeId: r.data.youtubeId,
    featured: r.data.featured,
  })),
].sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  const at = a.dateTs ?? 0;
  const bt = b.dateTs ?? 0;
  return bt - at;
});

const categoriesMap = new Map<string, string>();
for (const it of items) categoriesMap.set(it.category, categoryLabel(it.category));
const categories = [...categoriesMap.entries()].map(([value, label]) => ({ value, label }));

const kinds = [
  { value: 'blog', label: 'Články' },
  { value: 'video', label: 'Video' },
  { value: 'kniha', label: 'Knihy' },
  { value: 'meditace-audio', label: 'Audio' },
  { value: 'podcast', label: 'Podcast' },
];

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Zdroje', href: '/zdroje' },
];
---

<BaseLayout
  title="Zdroje — články, videa, knihy · Tergar Česko"
  description="Meditační obsah v češtině — články o práci s myslí, vedené meditace, vědecké výzkumy, knihy Mingyura Rinpočheho a videa. Filtrujte podle tématu."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Zdroje"
        title="Články, videa, knihy — inspirace pro praxi."
        lede="Sbírka obsahu pro ty, kdo chtějí meditaci prohloubit — vědecké výzkumy, praktické návody, osobní příběhy i tradiční učení."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Všechny zdroje"
        title="Filtrujte podle tématu a formátu."
      />
      <CategoryFilter categories={categories} kinds={kinds} client:visible />

      <ul class="cf-grid" aria-label="Obsah">
        {items.map((it) => (
          <li data-resource data-category={it.category} data-kind={it.kind}>
            <a
              href={it.href}
              class:list={['cf-card', { 'has-media': !!(it.thumb || it.youtubeId), 'no-media': !(it.thumb || it.youtubeId) }]}
              target={it.external ? '_blank' : undefined}
              rel={it.external ? 'noopener noreferrer' : undefined}
            >
              <div class="cf-kind">{it.kindLabel}</div>
              {it.thumb && (
                <div class="cf-thumb" style={`background-image:url(${it.thumb})`} aria-hidden="true" />
              )}
              {!it.thumb && it.youtubeId && (
                <div
                  class="cf-thumb"
                  style={`background-image:url(https://i.ytimg.com/vi/${it.youtubeId}/hqdefault.jpg)`}
                  aria-hidden="true"
                />
              )}
              <h3>{it.title}</h3>
              <p>{it.description}</p>
              <div class="cf-meta">
                <span class="cf-cat">{categoryLabel(it.category)}</span>
                {it.date && <time>{it.date}</time>}
              </div>
            </a>
          </li>
        ))}
      </ul>
      <p id="cf-empty" class="cf-empty" hidden>Žádný obsah pro zvolené filtry.</p>
    </Container>
  </Section>
</BaseLayout>

<style>
  /* Filter bar — left-aligned, never centered */
  :global(.cf-controls) {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2rem;
    justify-content: flex-start;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
  }
  :global(.cf-group) { display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start; min-width: 0; }
  :global(.cf-label) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
  }
  :global(.cf-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }
  :global(.cf-chip) {
    background: transparent;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-pill);
    padding: 0.3125rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
  }
  :global(.cf-chip:hover) { color: var(--ink); }
  :global(.cf-chip.is-active) { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  @media (max-width: 640px) {
    :global(.cf-controls) {
      padding: 1rem;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    :global(.cf-group) {
      width: 100%;
    }
    :global(.cf-row) {
      flex-wrap: nowrap;
      overflow-x: auto;
      width: 100%;
      padding-bottom: 0.125rem;
      scrollbar-width: none;
    }
    :global(.cf-row::-webkit-scrollbar) { display: none; }
  }

  .cf-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .cf-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .cf-grid { grid-template-columns: repeat(3, 1fr); } }
  .cf-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    color: inherit;
    text-decoration: none;
    transition: border-color .15s, transform .15s;
    height: 100%;
  }
  .cf-card.no-media {
    padding-top: 1.5rem;
  }
  .cf-card.no-media::before {
    content: '';
    width: 4rem;
    height: 1px;
    background: color-mix(in oklab, var(--accent) 55%, var(--line));
    margin-bottom: 0.25rem;
  }
  .cf-card:hover { border-color: var(--line-strong); }
  .cf-kind {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .cf-thumb {
    aspect-ratio: 4 / 2.4;
    border-radius: var(--radius-md);
    background-size: cover;
    background-position: center;
    background-color: var(--surface);
    margin-bottom: 0.5rem;
  }
  .cf-card h3 {
    font-size: 1.1875rem;
    margin: 0 0 0.375rem;
    line-height: 1.28;
    min-height: 3.1em;
  }
  .cf-card p {
    color: var(--ink-muted);
    margin: 0;
    font-size: 0.9375rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cf-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-soft);
  }
  .cf-cat { color: var(--ink-muted); }
  @media (max-width: 640px) {
    .cf-card h3 {
      min-height: 0;
    }
    .cf-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
  .cf-empty { color: var(--ink-muted); padding: 2rem 0; text-align: start; }
</style>
