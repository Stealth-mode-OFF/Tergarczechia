---
import { getEntry, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import Callout from '@/components/ui/Callout.astro';
import MeditationTimer from '@/components/timer/MeditationTimer.tsx';
import MobileActionBar from '@/components/ui/MobileActionBar.astro';

const entry = await getEntry('pages', 'meditace');
const { Content } = entry ? await render(entry) : { Content: null };
const title = entry?.data.title ?? 'Co je meditace';
const heroText = entry?.data.heroText ?? '';

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Co je meditace', href: '/meditace' },
];
---

<BaseLayout
  title={`${title} — Tergar Česko`}
  description="Meditace je tréninkem pozornosti — dovednost, která se dá naučit. Krátký úvod do toho, co meditace v Tergar tradici znamená a jak s ní začít."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Začátek"
        title="Naučte se dívat na svou mysl."
        lede={heroText}
        as="h1"
      />
      <div class="start-actions">
        <Button href="#zkuste-ted" variant="primary" size="lg">Zkusit 5 minut</Button>
        <Button href="/skupiny" variant="secondary" size="lg">Najít skupinu</Button>
      </div>
    </Container>
  </Section>

  <Section id="zkuste-ted" size="md" surface>
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Zkuste to teď"
        title="Pět minut. Bez závazku. Bez účtu."
        lede="Klikněte na 5, stiskněte Spustit a zavřete oči. Až uslyšíte zvonek, máte za sebou první minuty praxe. Zbytek článku počká."
      />
      <div class="try-dial">
        <MeditationTimer maxMinutes={30} defaultMinutes={5} compact client:only="preact" />
      </div>
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      <SectionHeader
        folio="03"
        eyebrow="Co vlastně děláme"
        title="Bez mystifikace, bez pózy."
      />
      <article class="prose">
        {Content && <Content />}
      </article>
      <Callout variant="quote" class="mid-quote">
        „Pokud si dokážete uvědomit, že vaše mysl bloudí, už meditujete."
        <div style="margin-top:.75rem; font-style:normal; font-family:var(--font-sans); font-size:.8125rem; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-muted);">
          — Mingyur Rinpočhe
        </div>
      </Callout>
      <div class="cta-row">
        <Button href="/cesta" variant="primary">Cesta Tergar</Button>
        <Button href="/skupiny" variant="secondary">Najít skupinu</Button>
        <Button href="/slovnik" variant="link" class="cta-link">Slovník pojmů</Button>
      </div>
    </Container>
  </Section>

  <MobileActionBar
    label="Rychlé akce na stránce meditace"
    actions={[
      { label: 'Zkusit 5 minut', href: '#zkuste-ted' },
      { label: 'Najít skupinu', href: '/skupiny', variant: 'secondary' },
    ]}
  />
</BaseLayout>

<style>
  .start-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .mid-quote { margin: 3rem 0; font-size: 1.375rem; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: flex-start; margin-top: 3rem; }
  .cta-link { align-self: center; }
  @media (max-width: 520px) {
    .start-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .cta-row {
      flex-direction: column;
      align-items: stretch;
    }
    .cta-link {
      align-self: flex-start;
      margin-top: 0.25rem;
    }
  }

  /* Timer sits on the section rail (left) on mobile, centered only when there's
     real empty space to absorb (desktop >= 800px). No forced center on mobile. */
  .try-dial {
    display: flex;
    justify-content: flex-start;
    margin-top: 1.5rem;
  }
  @media (min-width: 800px) {
    .try-dial { justify-content: center; }
  }
</style>
