---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout title="Stránka nenalezena — Tergar Česko" description="Tato stránka neexistuje nebo byla přesunuta." noindex>
  <section class="not-found">
    <Container>
      <p class="code">404</p>
      <h1>Tato stránka se kamsi zatoulala.</h1>
      <p class="lede">
        Možná jsme ji přejmenovali, možná nikdy neexistovala. Nejjednodušší je začít od začátku.
      </p>
      <div class="cta">
        <Button href="/" variant="primary">Na úvod</Button>
        <Button href="/skupiny" variant="ghost">Najít skupinu</Button>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-block: 4rem;
    text-align: center;
  }
  .code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.3em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .not-found h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    max-width: 22ch;
    margin-inline: auto;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }
  .lede { color: var(--ink-muted); max-width: 46ch; margin-inline: auto; margin-bottom: 2rem; }
  .cta { display: inline-flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
</style>
