---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

export async function getStaticPaths() {
  const entries = await getCollection('path');
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Cesta', href: '/cesta' },
  { label: entry.data.title, href: `/cesta/${entry.id}` },
];
---

<BaseLayout
  title={`${entry.data.title} — Cesta Tergar`}
  description={entry.data.subtitle}
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        eyebrow={`Úroveň ${entry.data.level}`}
        title={entry.data.title}
        lede={entry.data.subtitle}
        as="h1"
        class="head path-head"
      />
      <div class="meta">
        <Badge variant={entry.data.status === 'dostupne' ? 'accent' : 'outline'}>
          {entry.data.statusLabel ?? entry.data.status}
        </Badge>
        {entry.data.durationHours && (
          <Badge variant="outline">{entry.data.durationHours} hodin výuky</Badge>
        )}
      </div>
    </Container>
  </Section>

  <Section size="md">
    <Container size="prose">
      <article class="prose">
        <Content />
      </article>
      <div class="bottom-cta action-row">
        {entry.data.externalUrl && (
          <Button href={entry.data.externalUrl} variant="primary" external>
            Program na Tergar International
          </Button>
        )}
        <Button href="/cesta" variant="ghost">← Celá cesta</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .path-head { margin-bottom: 1.5rem; }
  .path-head :global(.lede) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.375rem;
    max-width: 52ch;
  }
  .meta { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .bottom-cta { margin-top: 3rem; }
</style>
