---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Badge from '@/components/ui/Badge.astro';

const steps = (await getCollection('path')).sort((a, b) => a.data.level - b.data.level);

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Cesta Tergar', href: '/cesta' },
];
---

<BaseLayout
  title="Cesta Tergar — meditační program krok za krokem"
  description="Navazující úrovně od Anytime Anywhere Meditation přes Joy of Living 1–3 po Path of Liberation a Vajrayana Online."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <header class="page-head">
        <p class="eyebrow">Cesta</p>
        <h1>Od prvního nádechu k Mahámudře.</h1>
        <p class="lead">
          Tergar program vede postupně — začíná u všedního dne, pokračuje přes klid, soucit a vhled, a vrcholí v tradiční praxi Karma Kagjü. Každý stupeň staví na předchozím, ale můžete vstoupit kdekoliv.
        </p>
      </header>
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <h2 class="section-label">Úrovně programu</h2>
      <ol class="timeline" aria-label="Úrovně cesty Tergar">
        {steps.map((step, i) => (
          <li class="step" data-status={step.data.status}>
            <div class="step-num" style={`--step-color: ${step.data.color}`} aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div class="step-content">
              <div class="step-head">
                <h3>
                  <a href={`/cesta/${step.id}`}>{step.data.title}</a>
                </h3>
                <Badge variant={step.data.status === 'dostupne' ? 'accent' : 'outline'}>
                  {step.data.statusLabel ?? step.data.status}
                </Badge>
              </div>
              <p class="step-sub">{step.data.subtitle}</p>
              {step.data.externalUrl && (
                <p class="step-link">
                  <a href={step.data.externalUrl} target="_blank" rel="noopener noreferrer">
                    Oficiální program Tergar International ↗
                  </a>
                </p>
              )}
            </div>
          </li>
        ))}
      </ol>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-head { max-width: 46rem; }
  .page-head h1 { margin-top: 1rem; margin-bottom: 1.25rem; text-wrap: balance; }
  .page-head .lead { font-size: 1.25rem; color: var(--ink-muted); max-width: 58ch; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.75rem;
  }
  .section-label {
    font-size: 1.125rem;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--ink-muted);
    margin: 0 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 27px;
    top: 16px;
    bottom: 16px;
    width: 1px;
    background: var(--line-strong);
    opacity: 0.5;
  }
  .step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .step:first-child { padding-top: 0; }
  .step-num {
    --step-color: var(--accent);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--step-color);
    background: var(--bg);
    border: 1.5px solid var(--step-color);
    position: relative;
    z-index: 1;
  }
  .step[data-status="vyzaduje-predchozi"] .step-num { opacity: 0.45; }
  .step-content { display: flex; flex-direction: column; gap: 0.375rem; padding-top: 0.75rem; }
  .step-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
  }
  .step-head h3 { margin: 0; font-size: 1.5rem; }
  .step-head a { color: var(--ink); text-decoration: none; }
  .step-head a:hover { color: var(--accent); }
  .step-sub { color: var(--ink-muted); margin: 0; }
  .step-link { margin: 0.25rem 0 0; font-size: 0.875rem; }
  .step-link a {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1px;
  }
  .step-link a:hover { color: var(--accent); border-color: var(--accent); }
</style>
