---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Badge from '@/components/ui/Badge.astro';

const steps = (await getCollection('path')).sort((a, b) => a.data.level - b.data.level);

const breadcrumbs = [
  { label: 'Domů', href: '/' },
  { label: 'Cesta Tergar', href: '/cesta' },
];
---

<BaseLayout
  title="Cesta Tergar — meditační program krok za krokem"
  description="Navazující úrovně od Anytime Anywhere Meditation přes Joy of Living 1–3 po Path of Liberation a Vajrayana Online."
  breadcrumbs={breadcrumbs}
  jsonLd={null}
>
  <Section size="md">
    <Container>
      <Breadcrumb items={breadcrumbs} />
      <SectionHeader
        folio="01"
        eyebrow="Cesta"
        title="Od prvního nádechu k Mahámudře."
        lede="Tergar program vede postupně — začíná u všedního dne, pokračuje přes klid, soucit a vhled, a vrcholí v tradiční praxi Karma Kagjü. Každý stupeň staví na předchozím, ale můžete vstoupit kdekoliv."
        as="h1"
      />
    </Container>
  </Section>

  <Section size="md">
    <Container>
      <SectionHeader
        folio="02"
        eyebrow="Úrovně programu"
        title="Deset kroků, jedna cesta."
      />
      <ol class="timeline" aria-label="Úrovně cesty Tergar">
        {steps.map((step, i) => (
          <li class="step" data-status={step.data.status}>
            <div class="step-num" style={`--step-color: ${step.data.color}`} aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div class="step-content">
              <div class="step-head">
                <h3>
                  <a href={`/cesta/${step.id}`}>{step.data.title}</a>
                </h3>
                <Badge variant={step.data.status === 'dostupne' ? 'accent' : 'outline'}>
                  {step.data.statusLabel ?? step.data.status}
                </Badge>
              </div>
              <p class="step-sub">{step.data.subtitle}</p>
              {step.data.externalUrl && (
                <p class="step-link">
                  <a href={step.data.externalUrl} target="_blank" rel="noopener noreferrer">
                    Oficiální program Tergar International ↗
                  </a>
                </p>
              )}
            </div>
          </li>
        ))}
      </ol>
    </Container>
  </Section>
</BaseLayout>

<style>
  /* Timeline — step-num sits ON the section rail (left edge), not outside it.
     The step content lines up directly next to the number, so heading left edge
     aligns with the section-header left edge on mobile (~21px). */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 19px;
    top: 16px;
    bottom: 16px;
    width: 1px;
    background: var(--line-strong);
    opacity: 0.45;
  }
  .step {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  @media (min-width: 640px) {
    .step { grid-template-columns: 48px 1fr; gap: 1.25rem; }
    .timeline::before { left: 23px; }
  }
  .step:first-child { padding-top: 0; }
  .step-num {
    --step-color: var(--accent);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--step-color);
    background: var(--bg);
    border: 1.5px solid var(--step-color);
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) {
    .step-num { width: 48px; height: 48px; font-size: 0.875rem; }
  }
  .step[data-status="vyzaduje-predchozi"] .step-num { opacity: 0.45; }
  .step-content { display: flex; flex-direction: column; gap: 0.375rem; padding-top: 0.375rem; }
  .step-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
  }
  .step-head h3 { margin: 0; font-size: 1.25rem; line-height: 1.3; }
  @media (min-width: 640px) { .step-head h3 { font-size: 1.5rem; } }
  .step-head a { color: var(--ink); text-decoration: none; }
  .step-head a:hover { color: var(--accent); }
  .step-sub { color: var(--ink-muted); margin: 0; font-size: 0.9375rem; }
  .step-link { margin: 0.25rem 0 0; font-size: 0.875rem; }
  .step-link a {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1px;
  }
  .step-link a:hover { color: var(--accent); border-color: var(--accent); }
</style>
