# Anthropic Claude API (AI admin endpoints)
ANTHROPIC_API_KEY=sk-ant-...

# Keystatic GitHub OAuth App (for /admin in production)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Optional: hard cost cap for AI admin
AI_MAX_USD_PER_MONTH=20

# Site URL (for preview envs, override at deploy)
PUBLIC_SITE_URL=https://tergarczechia.cz
