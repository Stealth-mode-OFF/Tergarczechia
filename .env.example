# Tergar Česko — env vars vzor
# Kopíruj do .env.local (dev) nebo přidávej přes `vercel env add` (prod).
# Kompletní návod: CMS_SETUP.md

# ──────────── Keystatic CMS ────────────

# Storage mode: "github" na produkci, neuváděj pro lokální vývoj (default = local)
KEYSTATIC_STORAGE=github

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: https://tergarczechia-three.vercel.app/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# JWT signing secret — vygeneruj: openssl rand -hex 32
KEYSTATIC_SECRET=

# ──────────── Supabase Auth (Google login pro /keystatic) ────────────

# Publishable: bezpečné v klientském kódu. Prefix PUBLIC_ je povinný pro Astro.
PUBLIC_SUPABASE_URL=https://egxxyszvwrqvkvlxawky.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_WjCsaepIZ4DvSbPk3aCRJQ_X7YHenZS

# Čárkou oddělený seznam e-mailů, které smí dovnitř Redakce.
# Každý jiný account bude po Google přihlášení odmítnut.
ADMIN_EMAILS=chatujsgpt@gmail.com

# ──────────── Registration form (přihlášky na akce) ────────────

# Resend API key — https://resend.com/api-keys (3000 e-mailů/měs. zdarma)
RESEND_API_KEY=

# From adresa pro notifikace — musí být z ověřené domény v Resendu
NOTIFY_FROM="Tergar Web <no-reply@tergarczechia.cz>"

# Fine-grained PAT pro commit přihlášek do repa (volitelné)
# Scope: Stealth-mode-OFF/Tergarczechia, Contents: Read+Write
# https://github.com/settings/personal-access-tokens/new
GITHUB_COMMIT_TOKEN=

# ──────────── Ostatní ────────────

# Anthropic Claude API (AI admin endpoints)
ANTHROPIC_API_KEY=sk-ant-...

# Hard cost cap for AI admin
AI_MAX_USD_PER_MONTH=20

# Site URL (pro preview envs, override at deploy)
PUBLIC_SITE_URL=https://tergarczechia.cz
